            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="purchases">
                <span class="bi bi-cart-check-fill-nav-menu" aria-hidden="true"></span> 採購管理
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="products">
                <span class="bi bi-box-seam-fill-nav-menu" aria-hidden="true"></span> 產品管理
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="customers">
