@page "/purchases"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@using MicroBoss.Application.Common
@using MicroBoss.Domain.Enums
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>採購管理 - MicroBoss</PageTitle>

<h4>採購管理</h4>

<div class="row mb-3 g-2 align-items-end">
    <div class="col-auto">
        <input class="form-control" placeholder="搜尋採購單號、供應商..."
               @bind="_keyword" @bind:event="oninput" @onkeyup="OnKeywordKeyUp" />
    </div>
    <div class="col-auto">
        <input type="date" class="form-control" @bind="_dateFrom" />
    </div>
    <div class="col-auto">
        <input type="date" class="form-control" @bind="_dateTo" />
    </div>
    <div class="col-auto">
        <select class="form-select" @bind="_statusFilter">
            <option value="">全部狀態</option>
            <option value="0">待處理</option>
            <option value="1">已採購</option>
        </select>
    </div>
    <div class="col-auto">
        <button class="btn btn-primary btn-sm" @onclick="Search">搜尋</button>
    </div>
    <div class="col-auto ms-auto">
        <button class="btn btn-success btn-sm" @onclick="NewPurchase">新增採購單</button>
    </div>
</div>

@if (_result == null)
{
    <p>載入中...</p>
}
else
{
    <table class="table table-striped table-sm table-hover">
        <thead>
            <tr>
                <th>採購單號</th>
                <th>供應商</th>
                <th>採購日期</th>
                <th>狀態</th>
                <th>稅額</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in _result.Items)
            {
                <tr style="cursor:pointer;" @onclick="() => EditPurchase(p.PurchaseId)">
                    <td>@p.PurchaseId</td>
                    <td>@p.SupplierShortName</td>
                    <td>@p.PurchaseDate?.ToString("yyyy/MM/dd")</td>
                    <td>@GetStatusText(p.Status)</td>
                    <td>@p.TaxAmount.ToString("N2")</td>
                    <td @onclick:stopPropagation>
                        <button class="btn btn-outline-primary btn-sm"
                                @onclick="() => EditPurchase(p.PurchaseId)">編輯</button>
                        <button class="btn btn-outline-danger btn-sm"
                                @onclick="() => ConfirmDelete(p)">刪除</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex align-items-center gap-3">
        <span class="text-muted small">共 @_result.TotalCount 筆，第 @_result.Page / @_result.TotalPages 頁</span>
        <button class="btn btn-outline-secondary btn-sm" disabled="@(_result.Page <= 1)"
                @onclick="PreviousPage">上一頁</button>
        <button class="btn btn-outline-secondary btn-sm" disabled="@(_result.Page >= _result.TotalPages)"
                @onclick="NextPage">下一頁</button>
        <select class="form-select form-select-sm w-auto" @bind="_pageSize" @bind:after="Search">
            <option value="10">10 筆/頁</option>
            <option value="20">20 筆/頁</option>
            <option value="50">50 筆/頁</option>
        </select>
    </div>
}

@if (_showConfirm && _deletingPurchase != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">確認刪除</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>確定要刪除採購單「@_deletingPurchase.PurchaseId」嗎？此操作無法還原。</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDelete">取消</button>
                    <button class="btn btn-danger" @onclick="DoDelete">確認刪除</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Inject] private IPurchaseService PurchaseService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private PagedResult<PurchaseDto>? _result;
    private string? _keyword;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private string _statusFilter = "";
    private int _page = 1;
    private int _pageSize = 20;
    private bool _showConfirm;
    private PurchaseDto? _deletingPurchase;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        PurchaseStatus? status = int.TryParse(_statusFilter, out var sv) ? (PurchaseStatus)sv : null;

        _result = await PurchaseService.QueryAsync(new PurchaseQueryDto
        {
            Keyword = _keyword,
            Status = status,
            DateFrom = _dateFrom,
            DateTo = _dateTo,
            Page = _page,
            PageSize = _pageSize
        });
    }

    private async Task Search()
    {
        _page = 1;
        await LoadData();
    }

    private async Task OnKeywordKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Search();
    }

    private async Task PreviousPage()
    {
        if (_page > 1) { _page--; await LoadData(); }
    }

    private async Task NextPage()
    {
        if (_result != null && _page < _result.TotalPages) { _page++; await LoadData(); }
    }

    private void NewPurchase() => Nav.NavigateTo("/purchases/new");
    private void EditPurchase(string id) => Nav.NavigateTo($"/purchases/{id}");

    private void ConfirmDelete(PurchaseDto purchase)
    {
        _deletingPurchase = purchase;
        _showConfirm = true;
    }

    private void CancelDelete()
    {
        _deletingPurchase = null;
        _showConfirm = false;
    }

    private async Task DoDelete()
    {
        if (_deletingPurchase != null)
        {
            await PurchaseService.DeleteAsync(_deletingPurchase.PurchaseId);
            _showConfirm = false;
            _deletingPurchase = null;
            await LoadData();
        }
    }

    private static string GetStatusText(PurchaseStatus? status) => status switch
    {
        PurchaseStatus.Pending => "待處理",
        PurchaseStatus.Purchased => "已採購",
        _ => "未知"
    };
}
