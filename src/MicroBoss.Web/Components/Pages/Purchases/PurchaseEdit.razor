@page "/purchases/new"
@page "/purchases/{Id}"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@using MicroBoss.Domain.Enums
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>@(_isNew ? "新增採購單" : $"編輯採購單 - {Id}") - MicroBoss</PageTitle>

<h4>@(_isNew ? "新增採購單" : $"編輯採購單 - {Id}")</h4>

@if (_loading)
{
    <p>載入中...</p>
}
else
{
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-3">
                <div class="card-header">採購單基本資料</div>
                <div class="card-body">
                    <DxFormLayout>
                        <DxFormLayoutItem Caption="供應商編號" ColSpanMd="6">
                            <DxTextBox @bind-Text="@_dto.SupplierId" @bind-Text:after="LookupSupplier" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="供應商名稱" ColSpanMd="6">
                            <DxTextBox Value="@_supplierName" ReadOnly="true" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="採購日期" ColSpanMd="4">
                            <DxDateEdit @bind-Date="@_purchaseDate" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="稅別" ColSpanMd="4">
                            <DxComboBox T="KeyValueOption" Data="@_taxTypeOptions"
                                        TextFieldName="@nameof(KeyValueOption.Label)"
                                        Value="@_taxTypeOption"
                                        ValueChanged="@((KeyValueOption opt) => OnTaxTypeOptionChanged(opt))" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="發票類型" ColSpanMd="4">
                            <DxComboBox T="KeyValueOption" Data="@_invoiceTypeOptions"
                                        TextFieldName="@nameof(KeyValueOption.Label)"
                                        Value="@_invoiceTypeOption"
                                        ValueChanged="@((KeyValueOption opt) => OnInvoiceTypeOptionChanged(opt))" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="採購備註" ColSpanMd="12">
                            <DxMemo @bind-Text="@_dto.PurchaseNote" Rows="2" />
                        </DxFormLayoutItem>
                    </DxFormLayout>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header">金額摘要</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-6">小計</dt>
                        <dd class="col-6 text-end">@_subTotal.ToString("N2")</dd>
                        <dt class="col-6">稅率</dt>
                        <dd class="col-6 text-end">@(_taxRate * 100).ToString("N0")%</dd>
                        <dt class="col-6">稅額</dt>
                        <dd class="col-6 text-end">@_taxAmount.ToString("N2")</dd>
                        <dt class="col-6 fw-bold">合計</dt>
                        <dd class="col-6 text-end fw-bold">
                            @(_taxTypeStr == "2" ? (_subTotal + _taxAmount).ToString("N2") : _subTotal.ToString("N2"))
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>採購明細</span>
            <button class="btn btn-sm btn-outline-success" @onclick="AddDetailRow">+ 新增明細</button>
        </div>
        <div class="card-body p-0">
            <DxGrid Data="@_details" ShowFilterRow="false" PagerVisible="false">
                <Columns>
                    <DxGridDataColumn FieldName="ProductNo" Caption="產品編號" Width="140px">
                        <CellDisplayTemplate>
                            @{ var item = (CreatePurchaseItemDto)context.DataItem; }
                            <input class="form-control form-control-sm" @bind="item.ProductNo" @bind:event="oninput" />
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="ProductChtName" Caption="產品名稱">
                        <CellDisplayTemplate>
                            @{ var item = (CreatePurchaseItemDto)context.DataItem; }
                            <input class="form-control form-control-sm" @bind="item.ProductChtName" />
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="Qty" Caption="數量" Width="90px">
                        <CellDisplayTemplate>
                            @{ var item = (CreatePurchaseItemDto)context.DataItem; }
                            <input type="number" class="form-control form-control-sm text-end" min="0"
                                   @bind="item.Qty" @bind:event="oninput" @onchange="RecalcTax" />
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="ItemPrice" Caption="單價" Width="110px">
                        <CellDisplayTemplate>
                            @{ var item = (CreatePurchaseItemDto)context.DataItem; }
                            <input type="number" class="form-control form-control-sm text-end" min="0" step="0.01"
                                   @bind="item.ItemPrice" @bind:event="oninput" @onchange="RecalcTax" />
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="ProductNo" Caption="小計" Width="110px">
                        <CellDisplayTemplate>
                            @{ var item = (CreatePurchaseItemDto)context.DataItem; }
                            <span class="float-end">@(((item.ItemPrice ?? 0) * (item.Qty ?? 0)).ToString("N2"))</span>
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridCommandColumn Width="60px">
                        <CellDisplayTemplate>
                            @{
                                var item = (CreatePurchaseItemDto)context.DataItem;
                                var idx = _details.IndexOf(item);
                            }
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveDetailRow(idx)">x</button>
                        </CellDisplayTemplate>
                    </DxGridCommandColumn>
                </Columns>
            </DxGrid>
            @if (_details.Count == 0)
            {
                <p class="text-center text-muted py-3 mb-0">尚無明細，請點擊「新增明細」</p>
            }
        </div>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-primary" @onclick="Save">儲存</button>
        <button class="btn btn-secondary" @onclick="Back">返回</button>
    </div>
}

@code {
    [Parameter] public string? Id { get; set; }
    [Inject] private IPurchaseService PurchaseService { get; set; } = default!;
    [Inject] private ISupplierService SupplierService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private bool _isNew;
    private bool _loading = true;
    private string _errorMessage = "";
    private CreatePurchaseDto _dto = new();
    private List<CreatePurchaseItemDto> _details = new();
    private string _taxTypeStr = "0";
    private string _invoiceTypeStr = "0";
    private DateTime? _purchaseDate = DateTime.Today;
    private string? _supplierName;
    private decimal _subTotal;
    private decimal _taxRate;
    private decimal _taxAmount;

    private record KeyValueOption(string Label, string Value);

    private readonly List<KeyValueOption> _taxTypeOptions = new()
    {
        new("無稅", "0"),
        new("內含稅", "1"),
        new("外加稅", "2"),
    };

    private readonly List<KeyValueOption> _invoiceTypeOptions = new()
    {
        new("無", "0"),
        new("二聯式", "2"),
        new("三聯式", "3"),
    };

    private KeyValueOption _taxTypeOption => _taxTypeOptions.FirstOrDefault(o => o.Value == _taxTypeStr) ?? _taxTypeOptions[0];
    private KeyValueOption _invoiceTypeOption => _invoiceTypeOptions.FirstOrDefault(o => o.Value == _invoiceTypeStr) ?? _invoiceTypeOptions[0];

    protected override async Task OnInitializedAsync()
    {
        _isNew = string.IsNullOrEmpty(Id) || Id == "new";

        if (!_isNew)
        {
            var existing = await PurchaseService.GetByIdAsync(Id!);
            if (existing == null)
            {
                Nav.NavigateTo("/purchases");
                return;
            }

            _dto = new CreatePurchaseDto
            {
                SupplierId = existing.SupplierId,
                PurchaseDate = existing.PurchaseDate,
                TaxType = (int)existing.TaxType,
                InvoiceType = (int)existing.InvoiceType,
                PurchaseNote = existing.PurchaseNote
            };

            _taxTypeStr = ((int)existing.TaxType).ToString();
            _invoiceTypeStr = ((int)existing.InvoiceType).ToString();
            _purchaseDate = existing.PurchaseDate ?? DateTime.Today;

            _details = existing.Details.Select(d => new CreatePurchaseItemDto
            {
                ProductId = d.ProductId,
                ProductNo = d.ProductNo,
                ProductChtName = d.ProductChtName,
                ItemPrice = d.ItemPrice,
                Qty = d.Qty,
                StockNo = d.StockNo,
                ItemNote = d.ItemNote
            }).ToList();

            if (!string.IsNullOrEmpty(existing.SupplierId))
            {
                var supplier = await SupplierService.GetByIdAsync(existing.SupplierId);
                _supplierName = supplier?.SupplierShortName;
            }
        }

        RecalcTax();
        _loading = false;
    }

    private async Task LookupSupplier()
    {
        _supplierName = null;
        if (!string.IsNullOrWhiteSpace(_dto.SupplierId))
        {
            var supplier = await SupplierService.GetByIdAsync(_dto.SupplierId.Trim());
            _supplierName = supplier?.SupplierShortName;
        }
    }

    private void OnTaxTypeOptionChanged(KeyValueOption opt)
    {
        _taxTypeStr = opt?.Value ?? "0";
        RecalcTax();
    }

    private void OnInvoiceTypeOptionChanged(KeyValueOption opt)
    {
        _invoiceTypeStr = opt?.Value ?? "0";
    }

    private void OnTaxTypeChanged(string value)
    {
        _taxTypeStr = value ?? "0";
        RecalcTax();
    }

    private void AddDetailRow()
    {
        _details.Add(new CreatePurchaseItemDto());
        RecalcTax();
    }

    private void RemoveDetailRow(int index)
    {
        if (index >= 0 && index < _details.Count)
        {
            _details.RemoveAt(index);
            RecalcTax();
        }
    }

    private void RecalcTax()
    {
        _subTotal = _details.Sum(d => (d.ItemPrice ?? 0) * (d.Qty ?? 0));

        var taxType = int.TryParse(_taxTypeStr, out var tv) ? (TaxType)tv : TaxType.None;
        (_taxRate, _taxAmount) = taxType switch
        {
            TaxType.None    => (0m, 0m),
            TaxType.Include => (0.05m, _subTotal - _subTotal / 1.05m),
            TaxType.Exclude => (0.05m, _subTotal * 0.05m),
            _               => (0m, 0m)
        };
    }

    private async Task Save()
    {
        _errorMessage = "";
        try
        {
            _dto.SupplierId = _dto.SupplierId?.Trim();
            _dto.PurchaseDate = _purchaseDate;
            _dto.TaxType = int.TryParse(_taxTypeStr, out var tv) ? tv : 0;
            _dto.InvoiceType = int.TryParse(_invoiceTypeStr, out var iv) ? iv : 0;
            _dto.Details = _details;

            if (_isNew)
            {
                var result = await PurchaseService.CreateAsync(_dto, "operator");
                Nav.NavigateTo($"/purchases/{result.PurchaseId}");
            }
            else
            {
                await PurchaseService.UpdateAsync(Id!, _dto);
                Nav.NavigateTo("/purchases");
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void Back() => Nav.NavigateTo("/purchases");
}
