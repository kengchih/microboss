@page "/products"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@using MicroBoss.Domain.Enums
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>產品管理 - MicroBoss</PageTitle>

<h4>產品管理</h4>

<div class="row mb-3 g-2 align-items-end">
    <div class="col-auto">
        <label class="form-label mb-1">產品類別</label>
        <DxComboBox Data="@_productClassOptions"
                    TextFieldName="Label"
                    ValueFieldName="Value"
                    @bind-Value="@_productClass"
                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                    NullText="全部類別" />
    </div>
    <div class="col-auto">
        <button class="btn btn-primary btn-sm" @onclick="Search">搜尋</button>
    </div>
    <div class="col-auto ms-auto">
        <button class="btn btn-success btn-sm" @onclick="NewProduct">新增產品</button>
    </div>
</div>

@if (_loading)
{
    <p>載入中...</p>
}
else if (_items == null)
{
    <p>無資料</p>
}
else
{
    <DxGrid Data="@_items"
            ShowFilterRow="true"
            PageSize="20"
            PagerVisible="true">
        <Columns>
            <DxGridDataColumn FieldName="ProductNo" Caption="產品編號" />
            <DxGridDataColumn FieldName="ProductName" Caption="產品名稱" />
            <DxGridDataColumn FieldName="Manufacturer" Caption="製造商" />
            <DxGridDataColumn FieldName="BaseUnit" Caption="單位" />
            <DxGridDataColumn FieldName="IsSuspend" Caption="停用">
                <CellDisplayTemplate>
                    @{
                        var product = (ProductDto)context.DataItem;
                    }
                    @(product.IsSuspend == true ? "是" : "否")
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridCommandColumn Width="150px">
                <CellDisplayTemplate>
                    @{
                        var product = (ProductDto)context.DataItem;
                    }
                    <button class="btn btn-outline-primary btn-sm" @onclick="() => EditProduct(product.ProductId)">編輯</button>
                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteProduct(product.ProductId)">刪除</button>
                </CellDisplayTemplate>
            </DxGridCommandColumn>
        </Columns>
    </DxGrid>
}

@code {
    [Inject] private IProductService ProductService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private List<ProductDto>? _items;
    private bool _loading = true;
    private string? _productClass;

    private readonly List<(string Label, string Value)> _productClassOptions = new()
    {
        ("存貨 (Stock)", "0"),
        ("非存貨 (Non-Stock)", "1"),
        ("服務 (Service)", "2"),
        ("工時 (Labor)", "3")
    };

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        ProductClass? pc = int.TryParse(_productClass, out var pcVal) ? (ProductClass)pcVal : null;
        var result = await ProductService.QueryAsync(new ProductQueryDto
        {
            ProductClass = pc,
            Page = 1,
            PageSize = int.MaxValue
        });
        _items = result.Items.ToList();
        _loading = false;
    }

    private async Task Search()
    {
        await LoadAsync();
    }

    private void NewProduct() => Nav.NavigateTo("/products/new");

    private void EditProduct(string id) => Nav.NavigateTo($"/products/{id}");

    private async Task DeleteProduct(string id)
    {
        await ProductService.DeleteAsync(id);
        await LoadAsync();
    }
}
