@page "/invoices/export"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@using Microsoft.JSInterop
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>發票匯出 - MicroBoss</PageTitle>

<h4>發票匯出</h4>

<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-2">
        <label class="form-label mb-1">開始日期</label>
        <input type="date" class="form-control" @bind="_dateFrom" />
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">結束日期</label>
        <input type="date" class="form-control" @bind="_dateTo" />
    </div>
    <div class="col-md-3 d-flex gap-2 align-items-end">
        <button class="btn btn-primary" @onclick="Search" disabled="@_loading">
            @(_loading ? "查詢中..." : "查詢")
        </button>
        @if (_data != null && _data.Count > 0)
        {
            <button class="btn btn-success" @onclick="ExportCsv">匯出 CSV</button>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger">@_errorMessage</div>
}

@if (_data != null)
{
    @if (_data.Count == 0)
    {
        <div class="alert alert-info">查無發票資料</div>
    }
    else
    {
        <div class="mb-2 text-muted">共 @_data.Count 筆</div>
        <div class="table-responsive">
            <table class="table table-striped table-sm table-hover">
                <thead class="table-light">
                    <tr>
                        <th>訂單號</th>
                        <th>訂單日期</th>
                        <th>客戶名稱</th>
                        <th>統一編號</th>
                        <th>發票抬頭</th>
                        <th>發票類型</th>
                        <th class="text-end">未稅金額</th>
                        <th class="text-end">稅額</th>
                        <th class="text-end">含稅合計</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _data)
                    {
                        <tr>
                            <td>@row.OrderNo</td>
                            <td>@row.OrderDate.ToString("yyyy/MM/dd")</td>
                            <td>@row.CustomerName</td>
                            <td>@row.UniteNo</td>
                            <td>@row.InvoiceTitle</td>
                            <td>@row.InvoiceTypeName</td>
                            <td class="text-end">@row.ItemAmount.ToString("N2")</td>
                            <td class="text-end">@row.TaxAmount.ToString("N2")</td>
                            <td class="text-end">@row.TotalAmount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light fw-bold">
                    <tr>
                        <td colspan="6">合計</td>
                        <td class="text-end">@_data.Sum(d => d.ItemAmount).ToString("N2")</td>
                        <td class="text-end">@_data.Sum(d => d.TaxAmount).ToString("N2")</td>
                        <td class="text-end">@_data.Sum(d => d.TotalAmount).ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
}

@code {
    [Inject] private IInvoiceService InvoiceService { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private DateTime _dateFrom = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime _dateTo = DateTime.Today;
    private List<InvoiceExportDto>? _data;
    private bool _loading;
    private string? _errorMessage;

    private async Task Search()
    {
        _errorMessage = null;
        _loading = true;
        try
        {
            _data = await InvoiceService.GetInvoiceExportDataAsync(_dateFrom, _dateTo);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ExportCsv()
    {
        if (_data == null || _data.Count == 0)
            return;

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("訂單號,訂單日期,客戶名稱,統一編號,發票抬頭,發票類型,未稅金額,稅額,含稅合計");

        foreach (var row in _data)
        {
            sb.AppendLine(string.Join(",",
                CsvEscape(row.OrderNo),
                CsvEscape(row.OrderDate.ToString("yyyy/MM/dd")),
                CsvEscape(row.CustomerName),
                CsvEscape(row.UniteNo),
                CsvEscape(row.InvoiceTitle),
                CsvEscape(row.InvoiceTypeName),
                row.ItemAmount.ToString("N2"),
                row.TaxAmount.ToString("N2"),
                row.TotalAmount.ToString("N2")));
        }

        var filename = $"invoice_export_{_dateFrom:yyyyMMdd}_{_dateTo:yyyyMMdd}.csv";
        // Prepend UTF-8 BOM so Excel opens Chinese characters correctly
        var content = "\uFEFF" + sb.ToString();
        await JS.InvokeVoidAsync("downloadFileFromText", filename, content, "text/csv;charset=utf-8");
    }

    private static string CsvEscape(string? value)
    {
        if (string.IsNullOrEmpty(value))
            return string.Empty;
        if (value.Contains(',') || value.Contains('"') || value.Contains('\n'))
            return $"\"{value.Replace("\"", "\"\"")}\"";
        return value;
    }
}
