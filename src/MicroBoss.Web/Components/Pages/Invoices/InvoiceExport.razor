@page "/invoices/export"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@using Microsoft.JSInterop
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>發票匯出 - MicroBoss</PageTitle>

<h4>發票匯出</h4>

<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-2">
        <label class="form-label mb-1">開始日期</label>
        <DxDateEdit @bind-Date="@_dateFrom" />
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">結束日期</label>
        <DxDateEdit @bind-Date="@_dateTo" />
    </div>
    <div class="col-md-3 d-flex gap-2 align-items-end">
        <DxButton Text="@(_loading ? "查詢中..." : "查詢")"
                  RenderStyle="ButtonRenderStyle.Primary"
                  Enabled="@(!_loading)"
                  Click="@Search" />
        @if (_data != null && _data.Count > 0)
        {
            <DxButton Text="匯出 CSV" RenderStyle="ButtonRenderStyle.Success" Click="@ExportCsv" />
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger">@_errorMessage</div>
}

@if (_data != null)
{
    @if (_data.Count == 0)
    {
        <div class="alert alert-info">查無發票資料</div>
    }
    else
    {
        <div class="mb-2 text-muted">共 @_data.Count 筆</div>
        <DxGrid Data="@_data" ShowFilterRow="true" PageSize="50">
            <Columns>
                <DxGridDataColumn FieldName="@nameof(InvoiceExportDto.OrderNo)" Caption="訂單號" />
                <DxGridDataColumn FieldName="@nameof(InvoiceExportDto.OrderDate)" Caption="訂單日期" DisplayFormat="yyyy/MM/dd" />
                <DxGridDataColumn FieldName="@nameof(InvoiceExportDto.CustomerName)" Caption="客戶名稱" />
                <DxGridDataColumn FieldName="@nameof(InvoiceExportDto.UniteNo)" Caption="統一編號" />
                <DxGridDataColumn FieldName="@nameof(InvoiceExportDto.InvoiceTitle)" Caption="發票抬頭" />
                <DxGridDataColumn FieldName="@nameof(InvoiceExportDto.InvoiceTypeName)" Caption="發票類型" />
                <DxGridDataColumn FieldName="@nameof(InvoiceExportDto.ItemAmount)" Caption="未稅金額" DisplayFormat="N2" Alignment="HorizontalAlignment.Right" />
                <DxGridDataColumn FieldName="@nameof(InvoiceExportDto.TaxAmount)" Caption="稅額" DisplayFormat="N2" Alignment="HorizontalAlignment.Right" />
                <DxGridDataColumn FieldName="@nameof(InvoiceExportDto.TotalAmount)" Caption="含稅合計" DisplayFormat="N2" Alignment="HorizontalAlignment.Right" />
            </Columns>
            <TotalSummary>
                <DxGridSummaryItem SummaryType="GridSummaryItemType.Sum" FieldName="@nameof(InvoiceExportDto.ItemAmount)" ValueDisplayFormat="N2" FooterColumnName="@nameof(InvoiceExportDto.ItemAmount)" />
                <DxGridSummaryItem SummaryType="GridSummaryItemType.Sum" FieldName="@nameof(InvoiceExportDto.TaxAmount)" ValueDisplayFormat="N2" FooterColumnName="@nameof(InvoiceExportDto.TaxAmount)" />
                <DxGridSummaryItem SummaryType="GridSummaryItemType.Sum" FieldName="@nameof(InvoiceExportDto.TotalAmount)" ValueDisplayFormat="N2" FooterColumnName="@nameof(InvoiceExportDto.TotalAmount)" />
            </TotalSummary>
        </DxGrid>
    }
}

@code {
    [Inject] private IInvoiceService InvoiceService { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private DateTime _dateFrom = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime _dateTo = DateTime.Today;
    private List<InvoiceExportDto>? _data;
    private bool _loading;
    private string? _errorMessage;

    private async Task Search()
    {
        _errorMessage = null;
        _loading = true;
        try
        {
            _data = await InvoiceService.GetInvoiceExportDataAsync(_dateFrom, _dateTo);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ExportCsv()
    {
        if (_data == null || _data.Count == 0)
            return;

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("訂單號,訂單日期,客戶名稱,統一編號,發票抬頭,發票類型,未稅金額,稅額,含稅合計");

        foreach (var row in _data)
        {
            sb.AppendLine(string.Join(",",
                CsvEscape(row.OrderNo),
                CsvEscape(row.OrderDate.ToString("yyyy/MM/dd")),
                CsvEscape(row.CustomerName),
                CsvEscape(row.UniteNo),
                CsvEscape(row.InvoiceTitle),
                CsvEscape(row.InvoiceTypeName),
                row.ItemAmount.ToString("N2"),
                row.TaxAmount.ToString("N2"),
                row.TotalAmount.ToString("N2")));
        }

        var filename = $"invoice_export_{_dateFrom:yyyyMMdd}_{_dateTo:yyyyMMdd}.csv";
        // Prepend UTF-8 BOM so Excel opens Chinese characters correctly
        var content = "\uFEFF" + sb.ToString();
        await JS.InvokeVoidAsync("downloadFileFromText", filename, content, "text/csv;charset=utf-8");
    }

    private static string CsvEscape(string? value)
    {
        if (string.IsNullOrEmpty(value))
            return string.Empty;
        if (value.Contains(',') || value.Contains('"') || value.Contains('\n'))
            return $"\"{value.Replace("\"", "\"\"")}\"";
        return value;
    }
}
