@page "/admin/comcodes"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@using MicroBoss.Domain.Enums
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<PageTitle>輔助代碼管理 - MicroBoss</PageTitle>

<h4>輔助代碼管理</h4>

<div class="row mb-3 align-items-end">
    <div class="col-auto">
        <label class="form-label fw-semibold">代碼群組</label>
        <DxComboBox T="string?" Data="@_groups"
                    Value="@_selectedGroup"
                    TextFieldName="@nameof(GroupOption.Label)"
                    ValueFieldName="@nameof(GroupOption.Value)"
                    NullText="-- 請選擇群組 --"
                    ValueChanged="@(async (string? v) => await OnGroupChanged(v))" />
    </div>
    @if (!string.IsNullOrEmpty(_selectedGroup))
    {
        <div class="col-auto">
            <DxButton Text="新增代碼" RenderStyle="ButtonRenderStyle.Primary" Click="@ShowCreateForm" />
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger alert-dismissible">
        @_errorMessage
        <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(_selectedGroup))
{
    @if (_codes == null)
    {
        <p>載入中...</p>
    }
    else if (_codes.Count == 0)
    {
        <p class="text-muted">此群組尚無代碼資料。</p>
    }
    else
    {
        <DxGrid Data="@_codes" ShowFilterRow="true" PageSize="30">
            <Columns>
                <DxGridDataColumn FieldName="@nameof(ComCodeDto.CodeId)" Caption="代碼 ID" />
                <DxGridDataColumn FieldName="@nameof(ComCodeDto.CodeName)" Caption="代碼名稱" />
                <DxGridDataColumn FieldName="@nameof(ComCodeDto.SortIndex)" Caption="排序" />
                <DxGridDataColumn Caption="操作" Width="150px">
                    <CellDisplayTemplate>
                        @{ var item = (ComCodeDto)context.DataItem; }
                        <DxButton Text="編輯" RenderStyle="ButtonRenderStyle.Secondary" Click="@(() => ShowEditForm(item))" />
                        <DxButton Text="刪除" RenderStyle="ButtonRenderStyle.Danger" Click="@(() => DeleteCode(item))" />
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
        </DxGrid>
    }
}

<!-- Add/Edit Popup -->
<DxPopup @bind-Visible="@_showForm" HeaderText="@(_isEditing ? "編輯代碼" : "新增代碼")" Width="450px">
    <BodyContentTemplate Context="_popupContext">
        @if (!string.IsNullOrEmpty(_formError))
        {
            <div class="alert alert-danger">@_formError</div>
        }
        <DxFormLayout>
            <DxFormLayoutItem Caption="群組 ID" ColSpanMd="12">
                <Template Context="_">
                    <DxTextBox Value="@_selectedGroup" ReadOnly="true" />
                </Template>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="代碼 ID" ColSpanMd="12">
                <Template Context="_">
                    @if (_isEditing)
                    {
                        <DxTextBox Value="@_formCodeId" ReadOnly="true" />
                    }
                    else
                    {
                        <DxTextBox @bind-Text="@_formCodeId" NullText="例如: 001" />
                    }
                </Template>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="代碼名稱" ColSpanMd="12">
                <Template Context="_">
                    <DxTextBox @bind-Text="@_formCodeName" NullText="代碼名稱" />
                </Template>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="排序" ColSpanMd="12">
                <Template Context="_">
                    <DxSpinEdit @bind-Value="@_formSortIndex" />
                </Template>
            </DxFormLayoutItem>
        </DxFormLayout>
    </BodyContentTemplate>
    <FooterContentTemplate Context="_popupFooter">
        <DxButton Text="取消" RenderStyle="ButtonRenderStyle.Secondary" Click="@CloseForm" />
        <DxButton Text="儲存" RenderStyle="ButtonRenderStyle.Primary" Click="@SaveCode" />
    </FooterContentTemplate>
</DxPopup>

@code {
    [Inject] private IComCodeService ComCodeService { get; set; } = default!;

    private record GroupOption(string Value, string Label);

    private static readonly List<GroupOption> _groups =
    [
        new(ComGroup.Manufactory,         "製造商"),
        new(ComGroup.Unit,                "單位"),
        new(ComGroup.Currency,            "貨幣"),
        new(ComGroup.SettleMethod,        "結算方法"),
        new(ComGroup.Stock,               "庫存"),
        new(ComGroup.Finance,             "財務"),
        new(ComGroup.Valuation,           "評價"),
        new(ComGroup.SupplierType,        "供應商類型"),
        new(ComGroup.PaymentType,         "支付類型"),
        new(ComGroup.ReceiptPayMethod,    "收付方式"),
        new(ComGroup.ProductMajorCategory,"產品大類"),
        new(ComGroup.ProductSubCategory,  "產品小類"),
        new(ComGroup.Voltage,             "電壓"),
        new(ComGroup.CustomerType,        "客戶類型"),
        new(ComGroup.CustomerTaxType,     "客戶稅型"),
        new(ComGroup.CustomerPaymentMethod,"客戶支付方式"),
        new(ComGroup.DeliveryMethod,      "交貨方式"),
        new(ComGroup.PurchaseItemType,    "採購項目類型"),
    ];

    private string _selectedGroup = string.Empty;
    private List<ComCodeDto>? _codes;
    private bool _showForm;
    private bool _isEditing;
    private string? _formError;
    private string? _errorMessage;

    // Form fields
    private string _formCodeId = string.Empty;
    private string _formCodeName = string.Empty;
    private int? _formSortIndex;

    private async Task OnGroupChanged(string? value)
    {
        _selectedGroup = value ?? string.Empty;
        await LoadCodesAsync();
    }

    private async Task LoadCodesAsync()
    {
        if (string.IsNullOrEmpty(_selectedGroup))
        {
            _codes = null;
            return;
        }
        try
        {
            _codes = await ComCodeService.GetByGroupAsync(_selectedGroup);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void ShowCreateForm()
    {
        _isEditing = false;
        _formCodeId = string.Empty;
        _formCodeName = string.Empty;
        _formSortIndex = null;
        _formError = null;
        _showForm = true;
    }

    private void ShowEditForm(ComCodeDto code)
    {
        _isEditing = true;
        _formCodeId = code.CodeId;
        _formCodeName = code.CodeName;
        _formSortIndex = code.SortIndex;
        _formError = null;
        _showForm = true;
    }

    private void CloseForm() => _showForm = false;

    private async Task SaveCode()
    {
        _formError = null;
        try
        {
            if (_isEditing)
            {
                var dto = new UpdateComCodeDto(_formCodeName, _formSortIndex);
                await ComCodeService.UpdateAsync(_selectedGroup, _formCodeId, dto);
            }
            else
            {
                if (string.IsNullOrWhiteSpace(_formCodeId))
                {
                    _formError = "代碼 ID 不可為空";
                    return;
                }
                var dto = new CreateComCodeDto(_selectedGroup, _formCodeId, _formCodeName, _formSortIndex);
                await ComCodeService.CreateAsync(dto);
            }
            _showForm = false;
            _codes = await ComCodeService.GetByGroupAsync(_selectedGroup);
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
    }

    private async Task DeleteCode(ComCodeDto code)
    {
        try
        {
            await ComCodeService.DeleteAsync(code.GroupId, code.CodeId);
            _codes = await ComCodeService.GetByGroupAsync(_selectedGroup);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }
}
