@page "/ar/posting"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@using MicroBoss.Application.Common
@using MicroBoss.Domain.Enums
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>收款總覽 - MicroBoss</PageTitle>

<h4>收款總覽</h4>

<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-2">
        <label class="form-label mb-1">年度</label>
        <DxSpinEdit @bind-Value="@_year" NullText="年度" MinValue="2000" MaxValue="2099" />
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">月份</label>
        <DxSpinEdit @bind-Value="@_month" NullText="月份" MinValue="1" MaxValue="12" />
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">客戶編號</label>
        <DxTextBox @bind-Text="@_customerId" NullText="客戶編號" ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
    </div>
    <div class="col-md-6 text-end">
        <DxButton Text="搜尋" RenderStyle="ButtonRenderStyle.Secondary" Click="@Search" />
    </div>
</div>

@if (_result == null)
{
    <p>載入中...</p>
}
else
{
    <DxGrid Data="@_postingRows" ShowFilterRow="true" PageSize="@_pageSize">
        <Columns>
            <DxGridDataColumn FieldName="@nameof(PostingRow.ArNumber)" Caption="應收單號">
                <CellDisplayTemplate>
                    @{ var row = (PostingRow)context.DataItem; }
                    <a href="/ar/@row.ArId" class="text-decoration-none">@row.ArNumber</a>
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="@nameof(PostingRow.SettleDate)" Caption="結帳日期" DisplayFormat="yyyy/MM/dd" />
            <DxGridDataColumn FieldName="@nameof(PostingRow.CustomerId)" Caption="客戶編號" />
            <DxGridDataColumn FieldName="@nameof(PostingRow.PostingDate)" Caption="收款日期" DisplayFormat="yyyy/MM/dd" />
            <DxGridDataColumn FieldName="@nameof(PostingRow.PostingType)" Caption="收款類型">
                <CellDisplayTemplate>
                    @GetPostingTypeText(((PostingRow)context.DataItem).PostingType)
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="@nameof(PostingRow.Amount)" Caption="收款金額" DisplayFormat="N2" Alignment="HorizontalAlignment.Right" />
        </Columns>
        <TotalSummary>
            <DxGridSummaryItem SummaryType="GridSummaryItemType.Sum" FieldName="@nameof(PostingRow.Amount)" ValueDisplayFormat="N2" FooterColumnName="@nameof(PostingRow.Amount)" />
        </TotalSummary>
    </DxGrid>

    <div class="d-flex align-items-center gap-3 mt-2">
        <span>共 @_result.TotalCount 筆應收帳款，收款記錄 @_postingRows.Count 筆</span>
        <DxButton Text="上一頁" RenderStyle="ButtonRenderStyle.Secondary"
                  Enabled="@(_result.Page > 1)" Click="@PreviousPage" />
        <DxButton Text="下一頁" RenderStyle="ButtonRenderStyle.Secondary"
                  Enabled="@(_result.Page < _result.TotalPages)" Click="@NextPage" />
        <DxComboBox T="int" Data="@_pageSizeOptions"
                    Value="@_pageSize"
                    ValueChanged="@(async (int v) => await OnPageSizeChanged(v))" />
    </div>
}

@code {
    [Inject] private IAccountsReceivableService ArService { get; set; } = default!;

    private PagedResult<AccountsReceivableDto>? _result;
    private List<PostingRow> _postingRows = new();

    private int? _year;
    private int? _month;
    private string? _customerId;
    private int _page = 1;
    private int _pageSize = 20;

    private static readonly List<int> _pageSizeOptions = [10, 20, 50];

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _result = await ArService.QueryAsync(new AccountsReceivableQueryDto
        {
            CustomerId = _customerId,
            Year = _year,
            Month = _month,
            Page = _page,
            PageSize = _pageSize
        });

        _postingRows = _result.Items
            .SelectMany(ar => ar.Postings.Select(p => new PostingRow
            {
                ArId = ar.Id,
                ArNumber = ar.Number,
                SettleDate = ar.SettleDate,
                CustomerId = ar.CustomerId,
                PostingDate = p.PostingDate,
                PostingType = p.Type,
                Amount = p.Amount
            }))
            .OrderByDescending(r => r.PostingDate)
            .ToList();
    }

    private async Task Search()
    {
        _page = 1;
        await LoadData();
    }

    private async Task PreviousPage()
    {
        if (_page > 1)
        {
            _page--;
            await LoadData();
        }
    }

    private async Task NextPage()
    {
        if (_result != null && _page < _result.TotalPages)
        {
            _page++;
            await LoadData();
        }
    }

    private async Task OnPageSizeChanged(int value)
    {
        _pageSize = value;
        _page = 1;
        await LoadData();
    }

    private static string GetPostingTypeText(AccountsReceivablePostingType type) => type switch
    {
        AccountsReceivablePostingType.Cash => "現金",
        AccountsReceivablePostingType.Remittance => "匯款",
        AccountsReceivablePostingType.Check => "支票",
        AccountsReceivablePostingType.Adjustment => "調帳",
        AccountsReceivablePostingType.Other => "其他",
        _ => type.ToString()
    };

    private sealed class PostingRow
    {
        public int ArId { get; set; }
        public string? ArNumber { get; set; }
        public DateTime SettleDate { get; set; }
        public string? CustomerId { get; set; }
        public DateTime PostingDate { get; set; }
        public AccountsReceivablePostingType PostingType { get; set; }
        public decimal Amount { get; set; }
    }
}
