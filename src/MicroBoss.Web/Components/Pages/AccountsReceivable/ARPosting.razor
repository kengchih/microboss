@page "/ar/posting"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@using MicroBoss.Application.Common
@using MicroBoss.Domain.Enums
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>收款總覽 - MicroBoss</PageTitle>

<h4>收款總覽</h4>

<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-2">
        <label class="form-label mb-1">年度</label>
        <input type="number" class="form-control" placeholder="年度 (e.g. 2025)" @bind="_year" />
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">月份</label>
        <input type="number" class="form-control" placeholder="月份 (1-12)" @bind="_month" min="1" max="12" />
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">客戶編號</label>
        <input class="form-control" placeholder="客戶編號" @bind="_customerId" />
    </div>
    <div class="col-md-6 text-end">
        <button class="btn btn-outline-secondary me-2" @onclick="Search">搜尋</button>
    </div>
</div>

@if (_result == null)
{
    <p>載入中...</p>
}
else
{
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>應收單號</th>
                <th>結帳日期</th>
                <th>客戶編號</th>
                <th>收款日期</th>
                <th>收款類型</th>
                <th class="text-end">收款金額</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in _postingRows)
            {
                <tr>
                    <td>
                        <a href="/ar/@row.ArId" class="text-decoration-none">@row.ArNumber</a>
                    </td>
                    <td>@row.SettleDate.ToString("yyyy/MM/dd")</td>
                    <td>@row.CustomerId</td>
                    <td>@row.PostingDate.ToString("yyyy/MM/dd")</td>
                    <td>@GetPostingTypeText(row.PostingType)</td>
                    <td class="text-end">@row.Amount.ToString("N2")</td>
                </tr>
            }
            @if (_postingRows.Count == 0)
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">無資料</td>
                </tr>
            }
        </tbody>
        @if (_postingRows.Count > 0)
        {
            <tfoot class="table-light fw-bold">
                <tr>
                    <td colspan="5" class="text-end">合計</td>
                    <td class="text-end">@_postingRows.Sum(r => r.Amount).ToString("N2")</td>
                </tr>
            </tfoot>
        }
    </table>

    <div class="d-flex align-items-center gap-3">
        <span>共 @_result.TotalCount 筆應收帳款，收款記錄 @_postingRows.Count 筆</span>
        <button class="btn btn-outline-secondary btn-sm" disabled="@(_result.Page <= 1)"
                @onclick="PreviousPage">上一頁</button>
        <button class="btn btn-outline-secondary btn-sm" disabled="@(_result.Page >= _result.TotalPages)"
                @onclick="NextPage">下一頁</button>
        <select class="form-select form-select-sm w-auto" @bind="_pageSize" @bind:after="Search">
            <option value="10">10 筆/頁</option>
            <option value="20">20 筆/頁</option>
            <option value="50">50 筆/頁</option>
        </select>
    </div>
}

@code {
    [Inject] private IAccountsReceivableService ArService { get; set; } = default!;

    private PagedResult<AccountsReceivableDto>? _result;
    private List<PostingRow> _postingRows = new();

    private int? _year;
    private int? _month;
    private string? _customerId;
    private int _page = 1;
    private int _pageSize = 20;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _result = await ArService.QueryAsync(new AccountsReceivableQueryDto
        {
            CustomerId = _customerId,
            Year = _year,
            Month = _month,
            Page = _page,
            PageSize = _pageSize
        });

        _postingRows = _result.Items
            .SelectMany(ar => ar.Postings.Select(p => new PostingRow
            {
                ArId = ar.Id,
                ArNumber = ar.Number,
                SettleDate = ar.SettleDate,
                CustomerId = ar.CustomerId,
                PostingDate = p.PostingDate,
                PostingType = p.Type,
                Amount = p.Amount
            }))
            .OrderByDescending(r => r.PostingDate)
            .ToList();
    }

    private async Task Search()
    {
        _page = 1;
        await LoadData();
    }

    private async Task PreviousPage()
    {
        if (_page > 1)
        {
            _page--;
            await LoadData();
        }
    }

    private async Task NextPage()
    {
        if (_result != null && _page < _result.TotalPages)
        {
            _page++;
            await LoadData();
        }
    }

    private static string GetPostingTypeText(AccountsReceivablePostingType type) => type switch
    {
        AccountsReceivablePostingType.Cash => "現金",
        AccountsReceivablePostingType.Remittance => "匯款",
        AccountsReceivablePostingType.Check => "支票",
        AccountsReceivablePostingType.Adjustment => "調帳",
        AccountsReceivablePostingType.Other => "其他",
        _ => type.ToString()
    };

    private sealed class PostingRow
    {
        public int ArId { get; set; }
        public string? ArNumber { get; set; }
        public DateTime SettleDate { get; set; }
        public string? CustomerId { get; set; }
        public DateTime PostingDate { get; set; }
        public AccountsReceivablePostingType PostingType { get; set; }
        public decimal Amount { get; set; }
    }
}
