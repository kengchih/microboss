@page "/ar/{Id:int}"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@using MicroBoss.Domain.Enums
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>應收帳款明細 - MicroBoss</PageTitle>

@if (_loading)
{
    <p>載入中...</p>
}
else if (_ar == null)
{
    <div class="alert alert-danger">找不到此應收帳款記錄</div>
    <DxButton Text="返回" RenderStyle="ButtonRenderStyle.Secondary" Click="@GoBack" />
}
else
{
    <div class="d-flex align-items-center mb-3 gap-2">
        <h4 class="mb-0">應收帳款明細 @_ar.Number</h4>
        <span class="badge @(_ar.Status == AccountsReceivableStatus.Paid ? "bg-success" : "bg-warning text-dark") ms-2">
            @GetStatusText(_ar.Status)
        </span>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }
    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="alert alert-success">@_successMessage</div>
    }

    <!-- Header Info -->
    <div class="card mb-3">
        <div class="card-header">基本資料</div>
        <div class="card-body">
            <DxFormLayout>
                <DxFormLayoutItem Caption="單號" ColSpanMd="3">
                    <Template><div class="form-control-plaintext">@_ar.Number</div></Template>
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="結帳日期" ColSpanMd="3">
                    <Template><div class="form-control-plaintext">@_ar.SettleDate.ToString("yyyy/MM/dd")</div></Template>
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="客戶編號" ColSpanMd="3">
                    <Template><div class="form-control-plaintext">@_ar.CustomerId</div></Template>
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="狀態" ColSpanMd="3">
                    <Template><div class="form-control-plaintext">@GetStatusText(_ar.Status)</div></Template>
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="訂單品項金額" ColSpanMd="3">
                    <Template><div class="form-control-plaintext text-end">@_ar.OrderItemAmount.ToString("N2")</div></Template>
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="稅額" ColSpanMd="3">
                    <Template><div class="form-control-plaintext text-end">@_ar.OrderTaxAmount.ToString("N2")</div></Template>
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="訂單合計" ColSpanMd="3">
                    <Template><div class="form-control-plaintext text-end">@_ar.OrderTotalAmount.ToString("N2")</div></Template>
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="應收總額" ColSpanMd="3">
                    <Template><div class="form-control-plaintext text-end fw-bold">@_ar.TotalAmount.ToString("N2")</div></Template>
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="實收金額" ColSpanMd="3">
                    <Template><div class="form-control-plaintext text-end text-success fw-bold">@_ar.ActualAmount.ToString("N2")</div></Template>
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="差額" ColSpanMd="3">
                    <Template>
                        <div class="form-control-plaintext text-end @((_ar.TotalAmount - _ar.ActualAmount) > 0 ? "text-danger" : "text-success") fw-bold">
                            @((_ar.TotalAmount - _ar.ActualAmount).ToString("N2"))
                        </div>
                    </Template>
                </DxFormLayoutItem>
            </DxFormLayout>
        </div>
    </div>

    <!-- Detail Table -->
    <div class="card mb-3">
        <div class="card-header">訂單明細</div>
        <div class="card-body p-0">
            <DxGrid Data="@_ar.Details" ShowFilterRow="false" PageSize="100">
                <Columns>
                    <DxGridDataColumn FieldName="@nameof(AccountsReceivableDetailDto.Type)" Caption="類型">
                        <CellDisplayTemplate>
                            @GetDetailTypeText(((AccountsReceivableDetailDto)context.DataItem).Type)
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="@nameof(AccountsReceivableDetailDto.OrderNo)" Caption="訂單號" />
                    <DxGridDataColumn FieldName="@nameof(AccountsReceivableDetailDto.Amount)" Caption="金額" DisplayFormat="N2" Alignment="HorizontalAlignment.Right" />
                    <DxGridDataColumn FieldName="@nameof(AccountsReceivableDetailDto.Note)" Caption="備註" />
                </Columns>
            </DxGrid>
        </div>
    </div>

    <!-- Postings Table -->
    <div class="card mb-3">
        <div class="card-header">收款紀錄</div>
        <div class="card-body p-0">
            <DxGrid Data="@_ar.Postings" ShowFilterRow="false" PageSize="100">
                <Columns>
                    <DxGridDataColumn FieldName="@nameof(AccountsReceivablePostingDto.PostingDate)" Caption="收款日期" DisplayFormat="yyyy/MM/dd" />
                    <DxGridDataColumn FieldName="@nameof(AccountsReceivablePostingDto.Type)" Caption="類型">
                        <CellDisplayTemplate>
                            @GetPostingTypeText(((AccountsReceivablePostingDto)context.DataItem).Type)
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="@nameof(AccountsReceivablePostingDto.Amount)" Caption="金額" DisplayFormat="N2" Alignment="HorizontalAlignment.Right" />
                    <DxGridDataColumn FieldName="@nameof(AccountsReceivablePostingDto.Account)" Caption="帳號" />
                    <DxGridDataColumn FieldName="@nameof(AccountsReceivablePostingDto.Bank)" Caption="銀行" />
                    <DxGridDataColumn FieldName="@nameof(AccountsReceivablePostingDto.CheckNumber)" Caption="支票號碼" />
                    <DxGridDataColumn FieldName="@nameof(AccountsReceivablePostingDto.Note)" Caption="備註" />
                </Columns>
            </DxGrid>
        </div>
    </div>

    <!-- Add Posting Form -->
    @if (_ar.Status == AccountsReceivableStatus.Unpaid)
    {
        <div class="card mb-3">
            <div class="card-header">新增收款</div>
            <div class="card-body">
                <DxFormLayout>
                    <DxFormLayoutItem Caption="收款日期 *" ColSpanMd="3">
                        <Template>
                            <DxDateEdit @bind-Date="@_postingDto.PostingDate" />
                        </Template>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="收款類型 *" ColSpanMd="3">
                        <Template>
                            <DxComboBox Data="@_postingTypeOptions"
                                        @bind-Value="@_postingTypeStr"
                                        TextFieldName="@nameof(PostingTypeOption.Label)"
                                        ValueFieldName="@nameof(PostingTypeOption.Value)" />
                        </Template>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="金額 *" ColSpanMd="3">
                        <Template>
                            <DxSpinEdit @bind-Value="@_postingDto.Amount" Increment="0.01m" MinValue="0" />
                        </Template>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="帳號" ColSpanMd="3">
                        <Template>
                            <DxTextBox @bind-Text="@_postingDto.Account" />
                        </Template>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="銀行" ColSpanMd="3">
                        <Template>
                            <DxTextBox @bind-Text="@_postingDto.Bank" />
                        </Template>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="支票號碼" ColSpanMd="3">
                        <Template>
                            <DxTextBox @bind-Text="@_postingDto.CheckNumber" />
                        </Template>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="支票日期" ColSpanMd="3">
                        <Template>
                            <DxDateEdit @bind-Date="@_postingDto.CheckDate" />
                        </Template>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="備註" ColSpanMd="6">
                        <Template>
                            <DxTextBox @bind-Text="@_postingDto.Note" />
                        </Template>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem ColSpanMd="12">
                        <Template>
                            <DxButton Text="@(_saving ? "儲存中..." : "新增收款")"
                                      RenderStyle="ButtonRenderStyle.Primary"
                                      Enabled="@(!_saving)"
                                      Click="@AddPosting" />
                        </Template>
                    </DxFormLayoutItem>
                </DxFormLayout>
            </div>
        </div>
    }

    <div class="d-flex gap-2 mt-2">
        <DxButton Text="返回" RenderStyle="ButtonRenderStyle.Secondary" Click="@GoBack" />
        @if (_ar.Status == AccountsReceivableStatus.Unpaid)
        {
            <DxButton Text="結帳" RenderStyle="ButtonRenderStyle.Success" Enabled="@(!_saving)" Click="@Close" />
        }
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    [Inject] private IAccountsReceivableService ArService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private bool _loading = true;
    private bool _saving;
    private string? _errorMessage;
    private string? _successMessage;
    private AccountsReceivableDto? _ar;

    private CreateAccountsReceivablePostingDto _postingDto = new()
    {
        PostingDate = DateTime.Today
    };
    private string _postingTypeStr = "0";

    private record PostingTypeOption(string Value, string Label);
    private static readonly List<PostingTypeOption> _postingTypeOptions =
    [
        new("0", "現金"),
        new("1", "匯款"),
        new("2", "支票"),
        new("8", "調帳"),
        new("9", "其他"),
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _ar = await ArService.GetByIdAsync(Id);
        _loading = false;
    }

    private async Task AddPosting()
    {
        _errorMessage = null;
        _successMessage = null;
        _saving = true;

        try
        {
            _postingDto.Type = int.TryParse(_postingTypeStr, out var t) ? t : 0;
            await ArService.AddPostingAsync(Id, _postingDto, string.Empty);
            _successMessage = "收款記錄新增成功";
            _postingDto = new CreateAccountsReceivablePostingDto { PostingDate = DateTime.Today };
            _postingTypeStr = "0";
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Close()
    {
        _errorMessage = null;
        _saving = true;

        try
        {
            await ArService.CloseAsync(Id);
            _successMessage = "已結帳";
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/ar");

    private static string GetStatusText(AccountsReceivableStatus status) => status switch
    {
        AccountsReceivableStatus.Unpaid => "未結帳",
        AccountsReceivableStatus.Paid => "已結帳",
        _ => status.ToString()
    };

    private static string GetDetailTypeText(AccountsReceivableType type) => type switch
    {
        AccountsReceivableType.Order => "訂單",
        AccountsReceivableType.Other => "其他",
        _ => type.ToString()
    };

    private static string GetPostingTypeText(AccountsReceivablePostingType type) => type switch
    {
        AccountsReceivablePostingType.Cash => "現金",
        AccountsReceivablePostingType.Remittance => "匯款",
        AccountsReceivablePostingType.Check => "支票",
        AccountsReceivablePostingType.Adjustment => "調帳",
        AccountsReceivablePostingType.Other => "其他",
        _ => type.ToString()
    };
}
