@page "/ar"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@using MicroBoss.Application.Common
@using MicroBoss.Domain.Enums
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>應收帳款 - MicroBoss</PageTitle>

<h4>應收帳款</h4>

<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-2">
        <label class="form-label mb-1">客戶編號</label>
        <input class="form-control" placeholder="客戶編號" @bind="_customerId" />
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">狀態</label>
        <select class="form-select" @bind="_statusFilter">
            <option value="">全部</option>
            <option value="0">未結帳</option>
            <option value="1">已結帳</option>
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">年度</label>
        <input type="number" class="form-control" placeholder="年度 (e.g. 2025)" @bind="_year" />
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">月份</label>
        <input type="number" class="form-control" placeholder="月份 (1-12)" @bind="_month" min="1" max="12" />
    </div>
    <div class="col-md-4 text-end">
        <button class="btn btn-outline-secondary me-2" @onclick="Search">搜尋</button>
    </div>
</div>

@if (_result == null)
{
    <p>載入中...</p>
}
else
{
    <table class="table table-striped table-sm table-hover">
        <thead>
            <tr>
                <th>單號</th>
                <th>結帳日期</th>
                <th>客戶編號</th>
                <th class="text-end">應收金額</th>
                <th class="text-end">實收金額</th>
                <th class="text-end">差額</th>
                <th>狀態</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ar in _result.Items)
            {
                <tr style="cursor:pointer;" @onclick="() => NavigateToEdit(ar.Id)">
                    <td>@ar.Number</td>
                    <td>@ar.SettleDate.ToString("yyyy/MM/dd")</td>
                    <td>@ar.CustomerId</td>
                    <td class="text-end">@ar.TotalAmount.ToString("N2")</td>
                    <td class="text-end">@ar.ActualAmount.ToString("N2")</td>
                    <td class="text-end">@((ar.TotalAmount - ar.ActualAmount).ToString("N2"))</td>
                    <td>
                        <span class="badge @(ar.Status == AccountsReceivableStatus.Paid ? "bg-success" : "bg-warning text-dark")">
                            @GetStatusText(ar.Status)
                        </span>
                    </td>
                </tr>
            }
            @if (_result.Items.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">無資料</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex align-items-center gap-3">
        <span>共 @_result.TotalCount 筆，第 @_result.Page / @_result.TotalPages 頁</span>
        <button class="btn btn-outline-secondary btn-sm" disabled="@(_result.Page <= 1)"
                @onclick="PreviousPage">上一頁</button>
        <button class="btn btn-outline-secondary btn-sm" disabled="@(_result.Page >= _result.TotalPages)"
                @onclick="NextPage">下一頁</button>
        <select class="form-select form-select-sm w-auto" @bind="_pageSize" @bind:after="Search">
            <option value="10">10 筆/頁</option>
            <option value="20">20 筆/頁</option>
            <option value="50">50 筆/頁</option>
        </select>
    </div>
}

@code {
    [Inject] private IAccountsReceivableService ArService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private PagedResult<AccountsReceivableDto>? _result;
    private string? _customerId;
    private string _statusFilter = "";
    private int? _year;
    private int? _month;
    private int _page = 1;
    private int _pageSize = 20;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        AccountsReceivableStatus? status = null;
        if (!string.IsNullOrEmpty(_statusFilter) && int.TryParse(_statusFilter, out var statusVal))
            status = (AccountsReceivableStatus)statusVal;

        _result = await ArService.QueryAsync(new AccountsReceivableQueryDto
        {
            CustomerId = _customerId,
            Status = status,
            Year = _year,
            Month = _month,
            Page = _page,
            PageSize = _pageSize
        });
    }

    private async Task Search()
    {
        _page = 1;
        await LoadData();
    }

    private async Task PreviousPage()
    {
        if (_page > 1)
        {
            _page--;
            await LoadData();
        }
    }

    private async Task NextPage()
    {
        if (_result != null && _page < _result.TotalPages)
        {
            _page++;
            await LoadData();
        }
    }

    private void NavigateToEdit(int id) => Nav.NavigateTo($"/ar/{id}");

    private static string GetStatusText(AccountsReceivableStatus status) => status switch
    {
        AccountsReceivableStatus.Unpaid => "未結帳",
        AccountsReceivableStatus.Paid => "已結帳",
        _ => status.ToString()
    };
}
