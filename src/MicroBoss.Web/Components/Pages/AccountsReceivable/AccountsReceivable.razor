@page "/ar"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@using MicroBoss.Application.Common
@using MicroBoss.Domain.Enums
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>應收帳款 - MicroBoss</PageTitle>

<h4>應收帳款</h4>

<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-2">
        <label class="form-label mb-1">客戶編號</label>
        <DxTextBox @bind-Text="@_customerId" ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" NullText="客戶編號" />
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">狀態</label>
        <DxComboBox Data="@_statusOptions" @bind-Value="@_statusFilter"
                    TextFieldName="@nameof(StatusOption.Label)"
                    ValueFieldName="@nameof(StatusOption.Value)"
                    NullText="全部" />
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">年度</label>
        <DxSpinEdit @bind-Value="@_year" NullText="年度" MinValue="2000" MaxValue="2099" />
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">月份</label>
        <DxSpinEdit @bind-Value="@_month" NullText="月份" MinValue="1" MaxValue="12" />
    </div>
    <div class="col-md-4 text-end">
        <DxButton Text="搜尋" RenderStyle="ButtonRenderStyle.Secondary" Click="@Search" />
    </div>
</div>

@if (_result == null)
{
    <p>載入中...</p>
}
else
{
    <DxGrid Data="@_result.Items"
            ShowFilterRow="true"
            PageSize="@_pageSize">
        <Columns>
            <DxGridDataColumn FieldName="@nameof(AccountsReceivableDto.Number)" Caption="單號" />
            <DxGridDataColumn FieldName="@nameof(AccountsReceivableDto.SettleDate)" Caption="結帳日期" DisplayFormat="yyyy/MM/dd" />
            <DxGridDataColumn FieldName="@nameof(AccountsReceivableDto.CustomerId)" Caption="客戶編號" />
            <DxGridDataColumn FieldName="@nameof(AccountsReceivableDto.TotalAmount)" Caption="應收金額" DisplayFormat="N2" Alignment="HorizontalAlignment.Right" />
            <DxGridDataColumn FieldName="@nameof(AccountsReceivableDto.ActualAmount)" Caption="實收金額" DisplayFormat="N2" Alignment="HorizontalAlignment.Right" />
            <DxGridDataColumn Caption="差額" Alignment="HorizontalAlignment.Right">
                <CellDisplayTemplate>
                    @{ var ar = (AccountsReceivableDto)context.DataItem; }
                    @((ar.TotalAmount - ar.ActualAmount).ToString("N2"))
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="@nameof(AccountsReceivableDto.Status)" Caption="狀態">
                <CellDisplayTemplate>
                    @{ var ar = (AccountsReceivableDto)context.DataItem; }
                    <span class="badge @(ar.Status == AccountsReceivableStatus.Paid ? "bg-success" : "bg-warning text-dark")">
                        @GetStatusText(ar.Status)
                    </span>
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="" Width="80px">
                <CellDisplayTemplate>
                    @{ var ar = (AccountsReceivableDto)context.DataItem; }
                    <DxButton Text="詳細" RenderStyle="ButtonRenderStyle.Secondary" Click="@(() => NavigateToEdit(ar.Id))" />
                </CellDisplayTemplate>
            </DxGridDataColumn>
        </Columns>
    </DxGrid>

    <div class="d-flex align-items-center gap-3 mt-2">
        <span>共 @_result.TotalCount 筆，第 @_result.Page / @_result.TotalPages 頁</span>
        <DxButton Text="上一頁" RenderStyle="ButtonRenderStyle.Secondary"
                  Enabled="@(_result.Page > 1)" Click="@PreviousPage" />
        <DxButton Text="下一頁" RenderStyle="ButtonRenderStyle.Secondary"
                  Enabled="@(_result.Page < _result.TotalPages)" Click="@NextPage" />
        <DxComboBox T="int" Data="@_pageSizeOptions"
                    Value="@_pageSize"
                    ValueChanged="@(async (int v) => await OnPageSizeChanged(v))" />
    </div>
}

@code {
    [Inject] private IAccountsReceivableService ArService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private PagedResult<AccountsReceivableDto>? _result;
    private string? _customerId;
    private string? _statusFilter;
    private int? _year;
    private int? _month;
    private int _page = 1;
    private int _pageSize = 20;

    private record StatusOption(string? Value, string Label);
    private static readonly List<StatusOption> _statusOptions =
    [
        new(null,  "全部"),
        new("0",   "未結帳"),
        new("1",   "已結帳"),
    ];

    private static readonly List<int> _pageSizeOptions = [10, 20, 50];

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        AccountsReceivableStatus? status = null;
        if (!string.IsNullOrEmpty(_statusFilter) && int.TryParse(_statusFilter, out var statusVal))
            status = (AccountsReceivableStatus)statusVal;

        _result = await ArService.QueryAsync(new AccountsReceivableQueryDto
        {
            CustomerId = _customerId,
            Status = status,
            Year = _year,
            Month = _month,
            Page = _page,
            PageSize = _pageSize
        });
    }

    private async Task Search()
    {
        _page = 1;
        await LoadData();
    }

    private async Task PreviousPage()
    {
        if (_page > 1)
        {
            _page--;
            await LoadData();
        }
    }

    private async Task NextPage()
    {
        if (_result != null && _page < _result.TotalPages)
        {
            _page++;
            await LoadData();
        }
    }

    private async Task OnPageSizeChanged(int value)
    {
        _pageSize = value;
        _page = 1;
        await LoadData();
    }

    private void NavigateToEdit(int id) => Nav.NavigateTo($"/ar/{id}");

    private static string GetStatusText(AccountsReceivableStatus status) => status switch
    {
        AccountsReceivableStatus.Unpaid => "未結帳",
        AccountsReceivableStatus.Paid => "已結帳",
        _ => status.ToString()
    };
}
