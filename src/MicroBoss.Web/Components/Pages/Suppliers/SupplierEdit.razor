@page "/suppliers/new"
@page "/suppliers/{Id}"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>@(_isNew ? "新增供應商" : "編輯供應商") - MicroBoss</PageTitle>

<h4>@(_isNew ? "新增供應商" : $"編輯供應商 - {_dto.SupplierShortName}")</h4>

@if (_loading)
{
    <p>載入中...</p>
}
else
{
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }

    <div class="card">
        <div class="card-body">
            <DxFormLayout>
                <DxFormLayoutItem Caption="供應商簡稱" ColSpanMd="6">
                    <DxTextBox @bind-Text="@_dto.SupplierShortName" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="供應商全名" ColSpanMd="6">
                    <DxTextBox @bind-Text="@_dto.SupplierFullName" />
                </DxFormLayoutItem>

                <DxFormLayoutItem Caption="抬頭" ColSpanMd="6">
                    <DxTextBox @bind-Text="@_dto.UniteTitle" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="供應商類型" ColSpanMd="3">
                    <DxTextBox @bind-Text="@_dto.SupplierType" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="稅別" ColSpanMd="3">
                    <DxTextBox @bind-Text="@_dto.TaxType" />
                </DxFormLayoutItem>

                <DxFormLayoutItem Caption="電話" ColSpanMd="4">
                    <DxTextBox @bind-Text="@_dto.Tel1" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="傳真" ColSpanMd="4">
                    <DxTextBox @bind-Text="@_dto.Fax" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Email" ColSpanMd="4">
                    <DxTextBox @bind-Text="@_dto.Email" />
                </DxFormLayoutItem>

                <DxFormLayoutItem Caption="聯絡窗口" ColSpanMd="6">
                    <DxTextBox @bind-Text="@_dto.ContactWindow" />
                </DxFormLayoutItem>

                <DxFormLayoutItem Caption="登記地址" ColSpanMd="12">
                    <DxTextBox @bind-Text="@_dto.RegisterAddress" />
                </DxFormLayoutItem>

                <DxFormLayoutItem Caption="備註" ColSpanMd="12">
                    <DxMemo @bind-Text="@_dto.Note" Rows="3" />
                </DxFormLayoutItem>
            </DxFormLayout>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary" @onclick="Save">儲存</button>
        <button class="btn btn-secondary" @onclick="GoBack">返回</button>
    </div>
}

@code {
    [Parameter] public string? Id { get; set; }
    [Inject] private ISupplierService SupplierService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private CreateSupplierDto _dto = new();
    private bool _isNew;
    private bool _loading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        _isNew = string.IsNullOrEmpty(Id) || Id == "new";

        if (!_isNew)
        {
            var existing = await SupplierService.GetByIdAsync(Id!);
            if (existing == null)
            {
                Nav.NavigateTo("/suppliers");
                return;
            }
            _dto = new CreateSupplierDto
            {
                SupplierShortName = existing.SupplierShortName,
                SupplierFullName = existing.SupplierFullName,
                UniteTitle = existing.UniteTitle,
                SupplierType = existing.SupplierType,
                TaxType = existing.TaxType,
                Tel1 = existing.Tel1,
                Fax = existing.Fax,
                Email = existing.Email,
                ContactWindow = existing.ContactWindow,
                RegisterAddress = existing.RegisterAddress,
                Note = existing.Note
            };
        }

        _loading = false;
    }

    private async Task Save()
    {
        _errorMessage = null;
        try
        {
            if (_isNew)
            {
                var result = await SupplierService.CreateAsync(_dto);
                Nav.NavigateTo($"/suppliers/{result.SupplierId}");
            }
            else
            {
                await SupplierService.UpdateAsync(Id!, _dto);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void GoBack() => Nav.NavigateTo("/suppliers");
}
