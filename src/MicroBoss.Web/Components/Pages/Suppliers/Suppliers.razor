@page "/suppliers"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@using MicroBoss.Application.Common
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>供應商管理 - MicroBoss</PageTitle>

<h4>供應商管理</h4>

<div class="mb-3 text-end">
    <button class="btn btn-primary btn-sm" @onclick="NavigateToNew">新增供應商</button>
</div>

@if (_items == null)
{
    <p>載入中...</p>
}
else
{
    <DxGrid Data="@_items"
            ShowFilterRow="true"
            PageSize="20"
            PagerVisible="true">
        <Columns>
            <DxGridDataColumn FieldName="SupplierId" Caption="供應商編號" />
            <DxGridDataColumn FieldName="SupplierShortName" Caption="簡稱" />
            <DxGridDataColumn FieldName="SupplierFullName" Caption="全名" />
            <DxGridDataColumn FieldName="Tel1" Caption="電話" />
            <DxGridDataColumn FieldName="ContactWindow" Caption="聯絡窗口" />
            <DxGridCommandColumn Width="150px">
                <CellDisplayTemplate>
                    @{
                        var supplier = (SupplierDto)context.DataItem;
                    }
                    <button class="btn btn-outline-primary btn-sm" @onclick="() => NavigateToEdit(supplier.SupplierId)">編輯</button>
                    <button class="btn btn-outline-danger btn-sm" @onclick="() => ConfirmDelete(supplier)">刪除</button>
                </CellDisplayTemplate>
            </DxGridCommandColumn>
        </Columns>
    </DxGrid>
}

@if (_showConfirm && _deletingSupplier != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">確認刪除</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>確定要刪除供應商「@_deletingSupplier.SupplierShortName（@_deletingSupplier.SupplierId）」嗎？</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDelete">取消</button>
                    <button class="btn btn-danger" @onclick="DoDelete">確認刪除</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Inject] private ISupplierService SupplierService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private List<SupplierDto>? _items;
    private bool _showConfirm;
    private SupplierDto? _deletingSupplier;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var result = await SupplierService.QueryAsync(new SupplierQueryDto
        {
            Page = 1,
            PageSize = int.MaxValue
        });
        _items = result.Items.ToList();
    }

    private void NavigateToNew() => Nav.NavigateTo("/suppliers/new");
    private void NavigateToEdit(string id) => Nav.NavigateTo($"/suppliers/{id}");

    private void ConfirmDelete(SupplierDto supplier)
    {
        _deletingSupplier = supplier;
        _showConfirm = true;
    }

    private void CancelDelete()
    {
        _deletingSupplier = null;
        _showConfirm = false;
    }

    private async Task DoDelete()
    {
        if (_deletingSupplier != null)
        {
            await SupplierService.DeleteAsync(_deletingSupplier.SupplierId);
            _showConfirm = false;
            _deletingSupplier = null;
            await LoadData();
        }
    }
}
