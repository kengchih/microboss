@page "/inventory/safe-stock"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>安全庫存警示 - MicroBoss</PageTitle>

<div class="d-flex align-items-center gap-3 mb-3">
    <h4 class="mb-0">安全庫存警示</h4>
    <a class="btn btn-outline-secondary btn-sm" href="/inventory">返回庫存管理</a>
</div>

@if (_loading)
{
    <p>載入中...</p>
}
else if (_items == null || _items.Count == 0)
{
    <div class="alert alert-success">目前所有產品庫存均高於安全存量。</div>
}
else
{
    <div class="alert alert-warning">共有 <strong>@_items.Count</strong> 項產品庫存低於安全存量，請盡快補貨。</div>

    <DxGrid Data="@_items"
            ShowFilterRow="true"
            PageSize="20"
            PagerVisible="true">
        <Columns>
            <DxGridDataColumn FieldName="ProductNo" Caption="產品編號" />
            <DxGridDataColumn FieldName="ProductName" Caption="產品名稱" />
            <DxGridDataColumn FieldName="StockNo" Caption="倉庫" />
            <DxGridDataColumn FieldName="CurrentStockQty" Caption="目前庫存">
                <CellDisplayTemplate>
                    @{
                        var item = (InventoryDto)context.DataItem;
                    }
                    <span class="text-danger fw-bold">@item.CurrentStockQty</span>
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="SafeQty" Caption="安全存量" />
            <DxGridDataColumn FieldName="SafeQty" Caption="不足量">
                <CellDisplayTemplate>
                    @{
                        var item = (InventoryDto)context.DataItem;
                        var shortage = item.SafeQty - item.CurrentStockQty;
                    }
                    <span class="text-danger fw-bold">@shortage</span>
                </CellDisplayTemplate>
            </DxGridDataColumn>
        </Columns>
    </DxGrid>
}

@code {
    [Inject] private IInventoryService InventoryService { get; set; } = default!;

    private List<InventoryDto>? _items;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _items = await InventoryService.GetUnderSafeQtyAsync();
        _loading = false;
    }
}
