@page "/inventory"
@using MicroBoss.Application.Common
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>庫存管理 - MicroBoss</PageTitle>

<h4>庫存管理</h4>

<div class="row mb-3 g-2 align-items-end">
    <div class="col-auto">
        <DxTextBox Text="@_keyword"
                   NullText="搜尋產品編號/名稱..."
                   TextChanged="@OnKeywordChanged" />
    </div>
    <div class="col-auto">
        <DxComboBox Data="@_stockNoOptions"
                    TextFieldName="@nameof(StockNoOption.Label)"
                    ValueFieldName="@nameof(StockNoOption.Value)"
                    @bind-Value="@_stockNo"
                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
    </div>
    <div class="col-auto">
        <button class="btn btn-primary btn-sm" @onclick="Search">搜尋</button>
    </div>
    <div class="col-auto">
        <a class="btn btn-warning btn-sm" href="/inventory/safe-stock">安全庫存警示</a>
    </div>
</div>

@if (_loading)
{
    <p>載入中...</p>
}
else if (_result == null || _result.Items.Count == 0)
{
    <p class="text-muted">無資料</p>
}
else
{
    <DxGrid Data="@_result.Items"
            ShowFilterRow="true"
            PageSize="20"
            PagerVisible="true"
            CustomizeElement="OnCustomizeElement">
        <Columns>
            <DxGridDataColumn FieldName="ProductNo" Caption="產品編號" />
            <DxGridDataColumn FieldName="ProductName" Caption="產品名稱">
                <CellDisplayTemplate>
                    @{
                        var item = (InventoryDto)context.DataItem;
                        var isUnderSafe = item.CurrentStockQty < item.SafeQty;
                    }
                    @item.ProductName
                    @if (isUnderSafe)
                    {
                        <span class="badge bg-danger ms-1" title="低於安全庫存">!</span>
                    }
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="Manufacturer" Caption="製造商" />
            <DxGridDataColumn FieldName="StockNo" Caption="倉庫" />
            <DxGridDataColumn FieldName="CurrentStockQty" Caption="庫存量" Width="90px">
                <CellDisplayTemplate>
                    @{
                        var item = (InventoryDto)context.DataItem;
                        var editKey = $"{item.ProductId}_{item.StockNo}";
                        var isEditing = _editingRows.Contains(editKey);
                    }
                    @if (isEditing)
                    {
                        <input type="number" class="form-control form-control-sm" style="width:80px"
                               @bind="_editQty" />
                    }
                    else
                    {
                        @item.CurrentStockQty
                    }
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="SafeQty" Caption="安全量" Width="90px">
                <CellDisplayTemplate>
                    @{
                        var item = (InventoryDto)context.DataItem;
                        var editKey = $"{item.ProductId}_{item.StockNo}";
                        var isEditing = _editingRows.Contains(editKey);
                    }
                    @if (isEditing)
                    {
                        <input type="number" class="form-control form-control-sm" style="width:80px"
                               @bind="_editSafeQty" />
                    }
                    else
                    {
                        @item.SafeQty
                    }
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="Location" Caption="儲位" Width="120px">
                <CellDisplayTemplate>
                    @{
                        var item = (InventoryDto)context.DataItem;
                        var editKey = $"{item.ProductId}_{item.StockNo}";
                        var isEditing = _editingRows.Contains(editKey);
                    }
                    @if (isEditing)
                    {
                        <input type="text" class="form-control form-control-sm" style="width:120px"
                               @bind="_editLocation" />
                    }
                    else
                    {
                        @item.Location
                    }
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="TransitQty" Caption="在途量" Width="80px" />
            <DxGridCommandColumn Width="150px">
                <CellDisplayTemplate>
                    @{
                        var item = (InventoryDto)context.DataItem;
                        var editKey = $"{item.ProductId}_{item.StockNo}";
                        var isEditing = _editingRows.Contains(editKey);
                    }
                    @if (isEditing)
                    {
                        <button class="btn btn-success btn-sm me-1" @onclick="() => SaveRow(item)">儲存</button>
                        <button class="btn btn-secondary btn-sm" @onclick="() => CancelEdit(editKey)">取消</button>
                    }
                    else
                    {
                        <button class="btn btn-outline-primary btn-sm" @onclick="() => StartEdit(item, editKey)">編輯</button>
                    }
                </CellDisplayTemplate>
            </DxGridCommandColumn>
        </Columns>
    </DxGrid>
}

@if (!string.IsNullOrEmpty(_statusMessage))
{
    <div class="alert @(_statusIsError ? "alert-danger" : "alert-success") alert-dismissible mt-2" role="alert">
        @_statusMessage
        <button type="button" class="btn-close" @onclick="() => _statusMessage = null"></button>
    </div>
}

@code {
    [Inject] private IInventoryService InventoryService { get; set; } = default!;

    private PagedResult<InventoryDto>? _result;
    private bool _loading = true;
    private string _keyword = "";
    private string? _stockNo;
    private int _page = 1;
    private const int PageSize = 20;

    private List<StockNoOption> _stockNoOptions = new();
    private HashSet<string> _editingRows = new();

    // Inline edit state (single row at a time)
    private string? _currentEditKey;
    private int _editQty;
    private int _editSafeQty;
    private string? _editLocation;

    private string? _statusMessage;
    private bool _statusIsError;

    private record StockNoOption(string Label, string? Value);

    protected override async Task OnInitializedAsync()
    {
        await LoadStockNosAsync();
        await LoadAsync();
    }

    private async Task LoadStockNosAsync()
    {
        var all = await InventoryService.QueryAsync(new InventoryQueryDto { Page = 1, PageSize = 1000 });
        var stockNos = all.Items.Select(i => i.StockNo ?? "").Where(s => !string.IsNullOrEmpty(s)).Distinct().OrderBy(s => s).ToList();
        _stockNoOptions = new List<StockNoOption> { new("全部倉庫", null) }
            .Concat(stockNos.Select(s => new StockNoOption(s, s)))
            .ToList();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _editingRows.Clear();
        _currentEditKey = null;

        _result = await InventoryService.QueryAsync(new InventoryQueryDto
        {
            Keyword = _keyword,
            StockNo = string.IsNullOrEmpty(_stockNo) ? null : _stockNo,
            Page = _page,
            PageSize = PageSize
        });
        _loading = false;
    }

    private async Task Search()
    {
        _page = 1;
        await LoadAsync();
    }

    private async Task OnKeywordChanged(string? value)
    {
        _keyword = value ?? "";
        await Task.CompletedTask;
    }

    private void OnCustomizeElement(GridCustomizeElementEventArgs e)
    {
        if (e.ElementType == GridElementType.DataRow)
        {
            var item = (InventoryDto)e.Grid.GetDataItem(e.VisibleIndex);
            if (item.CurrentStockQty < item.SafeQty)
                e.CssClass = "table-danger";
        }
    }

    private void StartEdit(InventoryDto item, string editKey)
    {
        if (_currentEditKey != null)
            _editingRows.Remove(_currentEditKey);

        _currentEditKey = editKey;
        _editQty = item.CurrentStockQty;
        _editSafeQty = item.SafeQty;
        _editLocation = item.Location;
        _editingRows.Add(editKey);
    }

    private void CancelEdit(string editKey)
    {
        _editingRows.Remove(editKey);
        _currentEditKey = null;
    }

    private async Task SaveRow(InventoryDto item)
    {
        try
        {
            await InventoryService.UpdateStockAsync(item.ProductId, item.StockNo!, _editQty, _editSafeQty, _editLocation);
            _statusMessage = $"已更新庫存：{item.ProductNo}";
            _statusIsError = false;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _statusMessage = $"更新失敗：{ex.Message}";
            _statusIsError = true;
        }
    }
}
