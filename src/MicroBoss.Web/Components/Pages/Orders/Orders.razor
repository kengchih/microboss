@page "/orders"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@using MicroBoss.Application.Common
@using MicroBoss.Domain.Enums
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>訂單管理 - MicroBoss</PageTitle>

<h4>訂單管理</h4>

<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-3">
        <label class="form-label mb-1">關鍵字</label>
        <div class="input-group">
            <input class="form-control" placeholder="訂單號、客戶編號、客戶名稱..."
                   @bind="_keyword" @bind:event="oninput" @onkeyup="OnKeywordKeyUp" />
            <button class="btn btn-outline-secondary" @onclick="Search">搜尋</button>
        </div>
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">開始日期</label>
        <input type="date" class="form-control" @bind="_dateFrom" />
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">結束日期</label>
        <input type="date" class="form-control" @bind="_dateTo" />
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">狀態</label>
        <select class="form-select" @bind="_statusFilter">
            <option value="">全部</option>
            <option value="0">待處理</option>
            <option value="1">未付款</option>
            <option value="2">已付款</option>
            <option value="3">已付款未結清</option>
            <option value="9">已作廢</option>
        </select>
    </div>
    <div class="col-md-3 text-end">
        <button class="btn btn-outline-secondary me-2" @onclick="Search">搜尋</button>
        <button class="btn btn-primary btn-sm" @onclick="NavigateToNew">新增訂單</button>
    </div>
</div>

@if (_result == null)
{
    <p>載入中...</p>
}
else
{
    <table class="table table-striped table-sm table-hover">
        <thead>
            <tr>
                <th>訂單號</th>
                <th>客戶名稱</th>
                <th>訂單日期</th>
                <th>狀態</th>
                <th>稅額</th>
                <th>應收金額</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in _result.Items)
            {
                <tr style="cursor:pointer;" @onclick="() => NavigateToEdit(order.OrderNo)">
                    <td>@order.OrderNo</td>
                    <td>@order.CustomerName</td>
                    <td>@order.OrderDate.ToString("yyyy/MM/dd")</td>
                    <td>@GetStatusText(order.Status)</td>
                    <td>@order.TaxAmount.ToString("N2")</td>
                    <td>@order.ActualAmount.ToString("N2")</td>
                    <td @onclick:stopPropagation>
                        <button class="btn btn-outline-primary btn-sm"
                                @onclick="() => NavigateToEdit(order.OrderNo)">編輯</button>
                        <button class="btn btn-outline-danger btn-sm"
                                @onclick="() => ConfirmDelete(order)">刪除</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex align-items-center gap-3">
        <span>共 @_result.TotalCount 筆，第 @_result.Page / @_result.TotalPages 頁</span>
        <button class="btn btn-outline-secondary btn-sm" disabled="@(_result.Page <= 1)"
                @onclick="PreviousPage">上一頁</button>
        <button class="btn btn-outline-secondary btn-sm" disabled="@(_result.Page >= _result.TotalPages)"
                @onclick="NextPage">下一頁</button>
        <select class="form-select form-select-sm w-auto" @bind="_pageSize" @bind:after="Search">
            <option value="10">10 筆/頁</option>
            <option value="20">20 筆/頁</option>
            <option value="50">50 筆/頁</option>
        </select>
    </div>
}

@if (_showConfirm && _deletingOrder != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">確認刪除</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>確定要刪除訂單「@_deletingOrder.OrderNo」嗎？</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDelete">取消</button>
                    <button class="btn btn-danger" @onclick="DoDelete">確認刪除</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Inject] private IOrderService OrderService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private PagedResult<OrderDto>? _result;
    private string? _keyword;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private string _statusFilter = "";
    private int _page = 1;
    private int _pageSize = 20;
    private bool _showConfirm;
    private OrderDto? _deletingOrder;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        OrderStatus? status = null;
        if (!string.IsNullOrEmpty(_statusFilter) && int.TryParse(_statusFilter, out var statusVal))
            status = (OrderStatus)statusVal;

        _result = await OrderService.QueryAsync(new OrderQueryDto
        {
            Keyword = _keyword,
            Status = status,
            DateFrom = _dateFrom,
            DateTo = _dateTo,
            Page = _page,
            PageSize = _pageSize
        });
    }

    private async Task Search()
    {
        _page = 1;
        await LoadData();
    }

    private async Task OnKeywordKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await Search();
    }

    private async Task PreviousPage()
    {
        if (_page > 1)
        {
            _page--;
            await LoadData();
        }
    }

    private async Task NextPage()
    {
        if (_result != null && _page < _result.TotalPages)
        {
            _page++;
            await LoadData();
        }
    }

    private void NavigateToNew() => Nav.NavigateTo("/orders/new");
    private void NavigateToEdit(string orderNo) => Nav.NavigateTo($"/orders/{orderNo}");

    private void ConfirmDelete(OrderDto order)
    {
        _deletingOrder = order;
        _showConfirm = true;
    }

    private void CancelDelete()
    {
        _deletingOrder = null;
        _showConfirm = false;
    }

    private async Task DoDelete()
    {
        if (_deletingOrder != null)
        {
            await OrderService.DeleteAsync(_deletingOrder.OrderNo);
            _showConfirm = false;
            _deletingOrder = null;
            await LoadData();
        }
    }

    private static string GetStatusText(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "待處理",
        OrderStatus.UnPaid => "未付款",
        OrderStatus.Closed => "已付款",
        OrderStatus.Unclear => "已付款未結清",
        OrderStatus.Invalid => "已作廢",
        _ => status.ToString()
    };
}
