@page "/orders"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@using MicroBoss.Application.Common
@using MicroBoss.Domain.Enums
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>訂單管理 - MicroBoss</PageTitle>

<h4>訂單管理</h4>

<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-3">
        <label class="form-label mb-1">關鍵字</label>
        <div class="input-group">
            <DxTextBox Text="@_keyword"
                       NullText="訂單號、客戶編號、客戶名稱..."
                       TextChanged="@OnKeywordChanged"
                       CssClass="flex-grow-1" />
            <button class="btn btn-outline-secondary" @onclick="Search">搜尋</button>
        </div>
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">開始日期</label>
        <DxDateEdit @bind-Date="@_dateFrom" />
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">結束日期</label>
        <DxDateEdit @bind-Date="@_dateTo" />
    </div>
    <div class="col-md-2">
        <label class="form-label mb-1">狀態</label>
        <DxComboBox Data="@_statusOptions"
                    TextFieldName="@nameof(StatusOption.Label)"
                    ValueFieldName="@nameof(StatusOption.Value)"
                    @bind-Value="@_statusFilter"
                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
    </div>
    <div class="col-md-3 text-end">
        <button class="btn btn-outline-secondary me-2" @onclick="Search">搜尋</button>
        <button class="btn btn-primary btn-sm" @onclick="NavigateToNew">新增訂單</button>
    </div>
</div>

@if (_result == null)
{
    <p>載入中...</p>
}
else
{
    <DxGrid Data="@_result.Items"
            ShowFilterRow="true"
            PageSize="20"
            PagerVisible="true">
        <Columns>
            <DxGridDataColumn FieldName="OrderNo" Caption="訂單號" />
            <DxGridDataColumn FieldName="CustomerName" Caption="客戶名稱" />
            <DxGridDataColumn FieldName="OrderDate" Caption="訂單日期" DisplayFormat="yyyy/MM/dd" />
            <DxGridDataColumn FieldName="Status" Caption="狀態">
                <CellDisplayTemplate>
                    @{
                        var order = (OrderDto)context.DataItem;
                    }
                    @GetStatusText(order.Status)
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn FieldName="TaxAmount" Caption="稅額" DisplayFormat="N2" />
            <DxGridDataColumn FieldName="ActualAmount" Caption="應收金額" DisplayFormat="N2" />
            <DxGridCommandColumn Width="150px">
                <CellDisplayTemplate>
                    @{
                        var order = (OrderDto)context.DataItem;
                    }
                    <button class="btn btn-outline-primary btn-sm"
                            @onclick="() => NavigateToEdit(order.OrderNo)">編輯</button>
                    <button class="btn btn-outline-danger btn-sm"
                            @onclick="() => ConfirmDelete(order)">刪除</button>
                </CellDisplayTemplate>
            </DxGridCommandColumn>
        </Columns>
    </DxGrid>
}

@if (_showConfirm && _deletingOrder != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">確認刪除</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>確定要刪除訂單「@_deletingOrder.OrderNo」嗎？</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDelete">取消</button>
                    <button class="btn btn-danger" @onclick="DoDelete">確認刪除</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Inject] private IOrderService OrderService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private PagedResult<OrderDto>? _result;
    private string? _keyword;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private string? _statusFilter;
    private int _page = 1;
    private int _pageSize = 20;
    private bool _showConfirm;
    private OrderDto? _deletingOrder;

    private record StatusOption(string Label, string? Value);

    private readonly List<StatusOption> _statusOptions = new()
    {
        new("全部", null),
        new("待處理", "0"),
        new("未付款",  "1"),
        new("已付款",  "2"),
        new("已付款未結清", "3"),
        new("已作廢",  "9"),
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        OrderStatus? status = null;
        if (!string.IsNullOrEmpty(_statusFilter) && int.TryParse(_statusFilter, out var statusVal))
            status = (OrderStatus)statusVal;

        _result = await OrderService.QueryAsync(new OrderQueryDto
        {
            Keyword = _keyword,
            Status = status,
            DateFrom = _dateFrom,
            DateTo = _dateTo,
            Page = _page,
            PageSize = _pageSize
        });
    }

    private async Task Search()
    {
        _page = 1;
        await LoadData();
    }

    private async Task OnKeywordChanged(string? value)
    {
        _keyword = value;
        await Task.CompletedTask;
    }

    private void NavigateToNew() => Nav.NavigateTo("/orders/new");
    private void NavigateToEdit(string orderNo) => Nav.NavigateTo($"/orders/{orderNo}");

    private void ConfirmDelete(OrderDto order)
    {
        _deletingOrder = order;
        _showConfirm = true;
    }

    private void CancelDelete()
    {
        _deletingOrder = null;
        _showConfirm = false;
    }

    private async Task DoDelete()
    {
        if (_deletingOrder != null)
        {
            await OrderService.DeleteAsync(_deletingOrder.OrderNo);
            _showConfirm = false;
            _deletingOrder = null;
            await LoadData();
        }
    }

    private static string GetStatusText(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "待處理",
        OrderStatus.UnPaid  => "未付款",
        OrderStatus.Closed  => "已付款",
        OrderStatus.Unclear => "已付款未結清",
        OrderStatus.Invalid => "已作廢",
        _                   => status.ToString()
    };
}
