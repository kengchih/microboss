@page "/orders/{Id}"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@using MicroBoss.Domain.Enums
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>@(_isNew ? "新增訂單" : "編輯訂單") - MicroBoss</PageTitle>

<h4>@(_isNew ? "新增訂單" : "編輯訂單") @(_isNew ? "" : $"  {Id}")</h4>

@if (_loading)
{
    <p>載入中...</p>
}
else
{
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }
    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="alert alert-success">@_successMessage</div>
    }

    <div class="card mb-3">
        <div class="card-header">訂單表頭</div>
        <div class="card-body">
            <DxFormLayout>
                <DxFormLayoutItem Caption="客戶編號" ColSpanMd="3">
                    <DxTextBox @bind-Text="@_dto.CustomerId"
                               NullText="輸入客戶編號" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="客戶名稱" ColSpanMd="4">
                    <DxTextBox @bind-Text="@_dto.CustomerName" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="訂單日期 *" ColSpanMd="3">
                    <DxDateEdit @bind-Date="@_dto.OrderDate" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="稅別" ColSpanMd="2">
                    <DxComboBox T="KeyValueOption" Data="@_taxTypeOptions"
                                TextFieldName="@nameof(KeyValueOption.Label)"
                                Value="@_taxTypeOption"
                                ValueChanged="@((KeyValueOption opt) => OnTaxTypeOptionChanged(opt))" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="發票類型" ColSpanMd="2">
                    <DxComboBox T="KeyValueOption" Data="@_invoiceTypeOptions"
                                TextFieldName="@nameof(KeyValueOption.Label)"
                                Value="@_invoiceTypeOption"
                                ValueChanged="@((KeyValueOption opt) => OnInvoiceTypeOptionChanged(opt))" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="預計出貨日" ColSpanMd="3">
                    <DxDateEdit @bind-Date="@_dto.DeliveryDate" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="付款方式" ColSpanMd="3">
                    <DxTextBox @bind-Text="@_dto.PaymentMethod" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="送貨地址" ColSpanMd="4">
                    <DxTextBox @bind-Text="@_dto.DeliveryAddress" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="統一編號" ColSpanMd="2">
                    <DxTextBox @bind-Text="@_dto.UniteNo" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="發票抬頭" ColSpanMd="3">
                    <DxTextBox @bind-Text="@_dto.InvoiceTitle" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="聯絡窗口" ColSpanMd="3">
                    <DxTextBox @bind-Text="@_dto.ContactWindow" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="郵遞區號" ColSpanMd="2">
                    <DxTextBox @bind-Text="@_dto.DeliveryAddressZip" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="送貨方式" ColSpanMd="2">
                    <DxTextBox @bind-Text="@_dto.DeliveryMethod" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="訂單備註" ColSpanMd="12">
                    <DxMemo @bind-Text="@_dto.OrderNote" Rows="2" />
                </DxFormLayoutItem>
            </DxFormLayout>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>訂單明細</span>
            <button class="btn btn-outline-primary btn-sm" @onclick="AddDetailRow">新增明細</button>
        </div>
        <div class="card-body p-0">
            <DxGrid Data="@_details" ShowFilterRow="false" PagerVisible="false">
                <Columns>
                    <DxGridDataColumn FieldName="ProductId" Caption="產品代碼" Width="130px">
                        <CellDisplayTemplate>
                            @{ var d = (CreateOrderDetailDto)context.DataItem; }
                            <input class="form-control form-control-sm" @bind="d.ProductId" />
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="ProductNo" Caption="產品編號" Width="100px">
                        <CellDisplayTemplate>
                            @{ var d = (CreateOrderDetailDto)context.DataItem; }
                            <input class="form-control form-control-sm" @bind="d.ProductNo" />
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="ProductName" Caption="產品名稱">
                        <CellDisplayTemplate>
                            @{ var d = (CreateOrderDetailDto)context.DataItem; }
                            <input class="form-control form-control-sm" @bind="d.ProductName" />
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="OrderUnit" Caption="單位" Width="80px">
                        <CellDisplayTemplate>
                            @{ var d = (CreateOrderDetailDto)context.DataItem; }
                            <input class="form-control form-control-sm" @bind="d.OrderUnit" />
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="OrderQty" Caption="數量" Width="80px">
                        <CellDisplayTemplate>
                            @{ var d = (CreateOrderDetailDto)context.DataItem; }
                            <input type="number" class="form-control form-control-sm" @bind="d.OrderQty" @bind:after="RecalcTotals" min="1" />
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="ItemPrice" Caption="單價" Width="100px">
                        <CellDisplayTemplate>
                            @{ var d = (CreateOrderDetailDto)context.DataItem; }
                            <input type="number" class="form-control form-control-sm" @bind="d.ItemPrice" @bind:after="RecalcTotals" />
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="ItemDiscount" Caption="折扣" Width="100px">
                        <CellDisplayTemplate>
                            @{ var d = (CreateOrderDetailDto)context.DataItem; }
                            <input type="number" class="form-control form-control-sm" @bind="d.ItemDiscount" @bind:after="RecalcTotals" />
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="OrderQty" Caption="小計" Width="110px">
                        <CellDisplayTemplate>
                            @{ var d = (CreateOrderDetailDto)context.DataItem; }
                            <span class="float-end">@((d.OrderQty * d.ItemPrice - d.ItemDiscount).ToString("N2"))</span>
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridCommandColumn Width="60px">
                        <CellDisplayTemplate>
                            @{
                                var d = (CreateOrderDetailDto)context.DataItem;
                                var idx = _details.IndexOf(d);
                            }
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveDetailRow(idx)">x</button>
                        </CellDisplayTemplate>
                    </DxGridCommandColumn>
                </Columns>
            </DxGrid>
            @if (_details.Count == 0)
            {
                <p class="text-center text-muted py-2 mb-0">尚無明細，請點選「新增明細」</p>
            }
        </div>
        <div class="card-footer">
            <div class="row justify-content-end">
                <div class="col-md-4">
                    <dl class="row mb-0">
                        <dt class="col-6">小計</dt>
                        <dd class="col-6 text-end">@_subTotal.ToString("N2")</dd>
                        <dt class="col-6">折扣</dt>
                        <dd class="col-6 text-end">@_totalDiscount.ToString("N2")</dd>
                        <dt class="col-6">稅額</dt>
                        <dd class="col-6 text-end">@_taxAmount.ToString("N2")</dd>
                        <dt class="col-6 fw-bold">合計</dt>
                        <dd class="col-6 text-end fw-bold">@_total.ToString("N2")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
            @(_saving ? "儲存中..." : "儲存")
        </button>
        <button class="btn btn-secondary" @onclick="GoBack">返回</button>
        @if (!_isNew)
        {
            <button class="btn btn-success" @onclick="Confirm" disabled="@_saving">確認訂單</button>
            <button class="btn btn-warning" @onclick="Invalidate" disabled="@_saving">作廢</button>
        }
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    [Inject] private IOrderService OrderService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private bool _isNew;
    private bool _loading = true;
    private bool _saving;
    private string? _errorMessage;
    private string? _successMessage;

    private CreateOrderDto _dto = new();
    private List<CreateOrderDetailDto> _details = new();
    private string _taxTypeStr = "0";
    private string _invoiceTypeStr = "0";

    private decimal _subTotal;
    private decimal _totalDiscount;
    private decimal _taxAmount;
    private decimal _total;

    private record KeyValueOption(string Label, string Value);

    private readonly List<KeyValueOption> _taxTypeOptions = new()
    {
        new("無稅", "0"),
        new("稅內含", "1"),
        new("稅外加", "2"),
    };

    private readonly List<KeyValueOption> _invoiceTypeOptions = new()
    {
        new("無", "0"),
        new("二聯式", "2"),
        new("三聯式", "3"),
    };

    private KeyValueOption _taxTypeOption => _taxTypeOptions.FirstOrDefault(o => o.Value == _taxTypeStr) ?? _taxTypeOptions[0];
    private KeyValueOption _invoiceTypeOption => _invoiceTypeOptions.FirstOrDefault(o => o.Value == _invoiceTypeStr) ?? _invoiceTypeOptions[0];

    protected override async Task OnInitializedAsync()
    {
        _isNew = string.Equals(Id, "new", StringComparison.OrdinalIgnoreCase);

        if (!_isNew)
        {
            var existing = await OrderService.GetByIdAsync(Id);
            if (existing == null)
            {
                _errorMessage = "找不到此訂單";
                _loading = false;
                return;
            }

            _dto = new CreateOrderDto
            {
                CustomerId = existing.CustomerId,
                CustomerName = existing.CustomerName,
                OrderDate = existing.OrderDate,
                TaxType = existing.TaxType.HasValue ? (int)existing.TaxType.Value : 0,
                InvoiceType = existing.InvoiceType.HasValue ? (int)existing.InvoiceType.Value : 0,
                DeliveryDate = existing.DeliveryDate,
                PaymentMethod = existing.PaymentMethod,
                DeliveryAddress = existing.DeliveryAddress,
                DeliveryMethod = existing.DeliveryMethod,
                OrderNote = existing.OrderNote,
                PrePayAmount = existing.PrePayAmount
            };

            _taxTypeStr = (_dto.TaxType ?? 0).ToString();
            _invoiceTypeStr = (_dto.InvoiceType ?? 0).ToString();

            _details = existing.OrderDetails.Select(d => new CreateOrderDetailDto
            {
                ProductId = d.ProductId,
                ProductNo = d.ProductNo,
                ProductName = d.ProductName,
                BaseUnit = d.BaseUnit,
                OrderUnit = d.OrderUnit,
                OrderQty = d.OrderQty,
                ItemPrice = d.ItemPrice,
                ItemDiscount = d.ItemDiscount,
                ItemNote = d.ItemNote
            }).ToList();
        }
        else
        {
            _dto.OrderDate = DateTime.Today;
        }

        _ = RecalcTotals();
        _loading = false;
    }

    private void OnCustomerIdChanged(string value) => _dto.CustomerId = value ?? string.Empty;

    private void OnTaxTypeOptionChanged(KeyValueOption opt)
    {
        _taxTypeStr = opt?.Value ?? "0";
        _ = RecalcTotals();
    }

    private void OnInvoiceTypeOptionChanged(KeyValueOption opt)
    {
        _invoiceTypeStr = opt?.Value ?? "0";
    }

    private void OnTaxTypeChanged(string value)
    {
        _taxTypeStr = value ?? "0";
        _ = RecalcTotals();
    }

    private void AddDetailRow()
    {
        _details.Add(new CreateOrderDetailDto { OrderQty = 1 });
        _ = RecalcTotals();
    }

    private void RemoveDetailRow(int index)
    {
        if (index >= 0 && index < _details.Count)
        {
            _details.RemoveAt(index);
            _ = RecalcTotals();
        }
    }

    private Task RecalcTotals()
    {
        _totalDiscount = _details.Sum(d => d.ItemDiscount);
        _subTotal = _details.Sum(d => d.OrderQty * d.ItemPrice - d.ItemDiscount);

        var taxType = (TaxType)(int.TryParse(_taxTypeStr, out var tv) ? tv : 0);

        switch (taxType)
        {
            case TaxType.Include:
                _taxAmount = Math.Round(_subTotal - _subTotal / 1.05m, 2);
                _total = _subTotal;
                break;
            case TaxType.Exclude:
                _taxAmount = Math.Round(_subTotal * 0.05m, 2);
                _total = _subTotal + _taxAmount;
                break;
            default:
                _taxAmount = 0m;
                _total = _subTotal;
                break;
        }

        return Task.CompletedTask;
    }

    private async Task Save()
    {
        _errorMessage = null;
        _successMessage = null;
        _saving = true;

        try
        {
            _dto.TaxType = int.TryParse(_taxTypeStr, out var tv) ? tv : 0;
            _dto.InvoiceType = int.TryParse(_invoiceTypeStr, out var iv) ? iv : 0;
            _dto.OrderDetails = _details;

            if (_isNew)
            {
                var result = await OrderService.CreateAsync(_dto, string.Empty);
                _successMessage = "新增成功";
                Nav.NavigateTo($"/orders/{result.OrderNo}");
            }
            else
            {
                await OrderService.UpdateAsync(Id, _dto);
                _successMessage = "儲存成功";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Confirm()
    {
        _errorMessage = null;
        _saving = true;
        try
        {
            await OrderService.ConfirmAsync(Id);
            _successMessage = "訂單已確認（未付款）";
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Invalidate()
    {
        _errorMessage = null;
        _saving = true;
        try
        {
            await OrderService.InvalidateAsync(Id);
            _successMessage = "訂單已作廢";
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/orders");
}
