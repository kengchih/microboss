@page "/customers"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@using MicroBoss.Application.Common
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>客戶管理 - MicroBoss</PageTitle>

<h4>客戶管理</h4>

<div class="mb-3 text-end">
    <button class="btn btn-primary btn-sm" @onclick="NavigateToNew">新增客戶</button>
</div>

@if (_items == null)
{
    <p>載入中...</p>
}
else
{
    <DxGrid Data="@_items"
            ShowFilterRow="true"
            PageSize="20"
            PagerVisible="true">
        <Columns>
            <DxGridDataColumn FieldName="CustomerId" Caption="客戶編號" />
            <DxGridDataColumn FieldName="CustomerName" Caption="客戶名稱" />
            <DxGridDataColumn FieldName="ShortName" Caption="簡稱" />
            <DxGridDataColumn FieldName="Tel1" Caption="電話" />
            <DxGridDataColumn FieldName="MobileNo" Caption="手機" />
            <DxGridDataColumn FieldName="ContactWindow" Caption="聯絡窗口" />
            <DxGridCommandColumn Width="150px">
                <CellDisplayTemplate>
                    @{
                        var customer = (CustomerDto)context.DataItem;
                    }
                    <button class="btn btn-outline-primary btn-sm" @onclick="() => NavigateToEdit(customer.CustomerId)">編輯</button>
                    <button class="btn btn-outline-danger btn-sm" @onclick="() => ConfirmDelete(customer)">刪除</button>
                </CellDisplayTemplate>
            </DxGridCommandColumn>
        </Columns>
    </DxGrid>
}

@if (_showConfirm && _deletingCustomer != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">確認刪除</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>確定要刪除客戶「@_deletingCustomer.CustomerName（@_deletingCustomer.CustomerId）」嗎？</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDelete">取消</button>
                    <button class="btn btn-danger" @onclick="DoDelete">確認刪除</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Inject] private ICustomerService CustomerService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private List<CustomerDto>? _items;
    private bool _showConfirm;
    private CustomerDto? _deletingCustomer;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var result = await CustomerService.QueryAsync(new CustomerQueryDto
        {
            Page = 1,
            PageSize = int.MaxValue
        });
        _items = result.Items.ToList();
    }

    private void NavigateToNew() => Nav.NavigateTo("/customers/new");
    private void NavigateToEdit(string id) => Nav.NavigateTo($"/customers/{id}");

    private void ConfirmDelete(CustomerDto customer)
    {
        _deletingCustomer = customer;
        _showConfirm = true;
    }

    private void CancelDelete()
    {
        _deletingCustomer = null;
        _showConfirm = false;
    }

    private async Task DoDelete()
    {
        if (_deletingCustomer != null)
        {
            await CustomerService.DeleteAsync(_deletingCustomer.CustomerId);
            _showConfirm = false;
            _deletingCustomer = null;
            await LoadData();
        }
    }
}
