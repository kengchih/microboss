@page "/customers"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@using MicroBoss.Application.Common
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>客戶管理 - MicroBoss</PageTitle>

<h4>客戶管理</h4>

<div class="row mb-3">
    <div class="col-md-4">
        <div class="input-group">
            <input class="form-control" placeholder="搜尋客戶編號、名稱、簡稱..."
                   @bind="_keyword" @bind:event="oninput" @onkeyup="OnKeywordKeyUp" />
            <button class="btn btn-outline-secondary" @onclick="Search">搜尋</button>
        </div>
    </div>
    <div class="col-md-8 text-end">
        <button class="btn btn-primary btn-sm" @onclick="NavigateToNew">新增客戶</button>
    </div>
</div>

@if (_result == null)
{
    <p>載入中...</p>
}
else
{
    <table class="table table-striped table-sm table-hover">
        <thead>
            <tr>
                <th>客戶編號</th>
                <th>客戶名稱</th>
                <th>簡稱</th>
                <th>電話</th>
                <th>手機</th>
                <th>聯絡窗口</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var customer in _result.Items)
            {
                <tr style="cursor:pointer;" @onclick="() => NavigateToEdit(customer.CustomerId)">
                    <td>@customer.CustomerId</td>
                    <td>@customer.CustomerName</td>
                    <td>@customer.ShortName</td>
                    <td>@customer.Tel1</td>
                    <td>@customer.MobileNo</td>
                    <td>@customer.ContactWindow</td>
                    <td @onclick:stopPropagation>
                        <button class="btn btn-outline-primary btn-sm"
                                @onclick="() => NavigateToEdit(customer.CustomerId)">編輯</button>
                        <button class="btn btn-outline-danger btn-sm"
                                @onclick="() => ConfirmDelete(customer)">刪除</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex align-items-center gap-3">
        <span>共 @_result.TotalCount 筆，第 @_result.Page / @_result.TotalPages 頁</span>
        <button class="btn btn-outline-secondary btn-sm" disabled="@(_result.Page <= 1)"
                @onclick="PreviousPage">上一頁</button>
        <button class="btn btn-outline-secondary btn-sm" disabled="@(_result.Page >= _result.TotalPages)"
                @onclick="NextPage">下一頁</button>
        <select class="form-select form-select-sm w-auto" @bind="_pageSize" @bind:after="Search">
            <option value="10">10 筆/頁</option>
            <option value="20">20 筆/頁</option>
            <option value="50">50 筆/頁</option>
        </select>
    </div>
}

@if (_showConfirm && _deletingCustomer != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">確認刪除</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>確定要刪除客戶「@_deletingCustomer.CustomerName（@_deletingCustomer.CustomerId）」嗎？</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDelete">取消</button>
                    <button class="btn btn-danger" @onclick="DoDelete">確認刪除</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Inject] private ICustomerService CustomerService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private PagedResult<CustomerDto>? _result;
    private string? _keyword;
    private int _page = 1;
    private int _pageSize = 20;
    private bool _showConfirm;
    private CustomerDto? _deletingCustomer;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _result = await CustomerService.QueryAsync(new CustomerQueryDto
        {
            Keyword = _keyword,
            Page = _page,
            PageSize = _pageSize
        });
    }

    private async Task Search()
    {
        _page = 1;
        await LoadData();
    }

    private async Task OnKeywordKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await Search();
    }

    private async Task PreviousPage()
    {
        if (_page > 1)
        {
            _page--;
            await LoadData();
        }
    }

    private async Task NextPage()
    {
        if (_result != null && _page < _result.TotalPages)
        {
            _page++;
            await LoadData();
        }
    }

    private void NavigateToNew() => Nav.NavigateTo("/customers/new");
    private void NavigateToEdit(string id) => Nav.NavigateTo($"/customers/{id}");

    private void ConfirmDelete(CustomerDto customer)
    {
        _deletingCustomer = customer;
        _showConfirm = true;
    }

    private void CancelDelete()
    {
        _deletingCustomer = null;
        _showConfirm = false;
    }

    private async Task DoDelete()
    {
        if (_deletingCustomer != null)
        {
            await CustomerService.DeleteAsync(_deletingCustomer.CustomerId);
            _showConfirm = false;
            _deletingCustomer = null;
            await LoadData();
        }
    }
}
