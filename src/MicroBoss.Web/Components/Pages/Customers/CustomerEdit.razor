@page "/customers/{Id}"
@using MicroBoss.Application.DTOs
@using MicroBoss.Application.Interfaces
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>@(_isNew ? "新增客戶" : "編輯客戶") - MicroBoss</PageTitle>

<h4>@(_isNew ? "新增客戶" : "編輯客戶")</h4>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger">@_errorMessage</div>
}

@if (!string.IsNullOrEmpty(_successMessage))
{
    <div class="alert alert-success">@_successMessage</div>
}

<div class="card">
    <div class="card-body">
        <DxFormLayout>
            <DxFormLayoutItem Caption="客戶編號 *" ColSpanMd="3">
                <DxTextBox @bind-Text="@_dto.CustomerId" ReadOnly="@(!_isNew)" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="客戶名稱" ColSpanMd="4">
                <DxTextBox @bind-Text="@_dto.CustomerName" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="簡稱" ColSpanMd="3">
                <DxTextBox @bind-Text="@_dto.ShortName" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="客戶類型" ColSpanMd="2">
                <DxTextBox @bind-Text="@_dto.CustomerType" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="統一編號" ColSpanMd="3">
                <DxTextBox @bind-Text="@_dto.UnitNo" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="稅別" ColSpanMd="2">
                <DxTextBox @bind-Text="@_dto.TaxType" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="發票抬頭" ColSpanMd="4">
                <DxTextBox @bind-Text="@_dto.InvoiceTitle" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="電話" ColSpanMd="3">
                <DxTextBox @bind-Text="@_dto.Tel1" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="傳真" ColSpanMd="3">
                <DxTextBox @bind-Text="@_dto.Fax" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="手機" ColSpanMd="3">
                <DxTextBox @bind-Text="@_dto.MobileNo" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Email" ColSpanMd="3">
                <DxTextBox @bind-Text="@_dto.Email" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="聯絡窗口" ColSpanMd="3">
                <DxTextBox @bind-Text="@_dto.ContactWindow" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="送貨地址" ColSpanMd="4">
                <DxTextBox @bind-Text="@_dto.DeliveryAddress" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="郵遞區號" ColSpanMd="2">
                <DxTextBox @bind-Text="@_dto.DeliveryAddressZip" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="付款方式" ColSpanMd="3">
                <DxTextBox @bind-Text="@_dto.PaymentMethod" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="送貨方式" ColSpanMd="3">
                <DxTextBox @bind-Text="@_dto.DeliveryMethod" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="備註" ColSpanMd="12">
                <DxMemo @bind-Text="@_dto.Note" Rows="3" />
            </DxFormLayoutItem>
        </DxFormLayout>
    </div>
    <div class="card-footer d-flex gap-2">
        <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
            @(_saving ? "儲存中..." : "儲存")
        </button>
        <button class="btn btn-secondary" @onclick="GoBack">返回</button>
    </div>
</div>

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    [Inject] private ICustomerService CustomerService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private CreateCustomerDto _dto = new();
    private bool _isNew;
    private bool _saving;
    private string? _errorMessage;
    private string? _successMessage;

    protected override async Task OnInitializedAsync()
    {
        _isNew = string.Equals(Id, "new", StringComparison.OrdinalIgnoreCase);

        if (!_isNew)
        {
            var existing = await CustomerService.GetByIdAsync(Id);
            if (existing == null)
            {
                _errorMessage = "找不到此客戶";
                return;
            }

            _dto = new CreateCustomerDto
            {
                CustomerId = existing.CustomerId,
                CustomerName = existing.CustomerName,
                ShortName = existing.ShortName,
                CustomerType = existing.CustomerType,
                UnitNo = existing.UnitNo,
                TaxType = existing.TaxType,
                InvoiceTitle = existing.InvoiceTitle,
                Tel1 = existing.Tel1,
                Fax = existing.Fax,
                MobileNo = existing.MobileNo,
                Email = existing.Email,
                ContactWindow = existing.ContactWindow,
                DeliveryAddress = existing.DeliveryAddress,
                DeliveryAddressZip = existing.DeliveryAddressZip,
                PaymentMethod = existing.PaymentMethod,
                DeliveryMethod = existing.DeliveryMethod,
                Note = existing.Note
            };
        }
    }

    private async Task Save()
    {
        _errorMessage = null;
        _successMessage = null;

        if (string.IsNullOrWhiteSpace(_dto.CustomerId))
        {
            _errorMessage = "客戶編號為必填";
            return;
        }

        _saving = true;
        try
        {
            if (_isNew)
            {
                await CustomerService.CreateAsync(_dto);
                _successMessage = "新增成功";
                Nav.NavigateTo($"/customers/{_dto.CustomerId}");
            }
            else
            {
                await CustomerService.UpdateAsync(Id, _dto);
                _successMessage = "儲存成功";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/customers");
}
